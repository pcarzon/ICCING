        RowBox[{"RandomReal", "[", 
         RowBox[{"{", 
          RowBox[{"bmin", ",", "bmax"}], "}"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"n1", "[", 
        RowBox[{"x_", ",", "y_"}], "]"}], "=", " ", 
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{
          FractionBox["1", 
           RowBox[{"2", "\[Pi]", " ", 
            SuperscriptBox["sigma", "2"]}]], 
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"-", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"x", "-", 
                  RowBox[{
                   RowBox[{"ptsACol", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "[", 
                   RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "^", "2"}]}], "/",
               "2"}], "/", 
             RowBox[{"sigma", "^", "2"}]}], " ", "-", " ", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"y", "-", 
                 RowBox[{
                  RowBox[{"ptsACol", "[", 
                   RowBox[{"[", "i", "]"}], "]"}], "[", 
                  RowBox[{"[", "2", "]"}], "]"}]}], ")"}], "^", "2"}], "/", 
              "2"}], "/", 
             RowBox[{"sigma", "^", "2"}]}]}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", 
           RowBox[{"Length", "[", "ptsACol", "]"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"n2", "[", 
        RowBox[{"x_", ",", "y_"}], "]"}], "=", 
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{
          FractionBox["1", 
           RowBox[{"2", "\[Pi]", " ", 
            SuperscriptBox["sigma", "2"]}]], 
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"-", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"x", "-", 
                  RowBox[{
                   RowBox[{"ptsBCol", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "[", 
                   RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "^", "2"}]}], "/",
               "2"}], "/", 
             RowBox[{"sigma", "^", "2"}]}], " ", "-", " ", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"y", "-", 
                 RowBox[{
                  RowBox[{"ptsBCol", "[", 
                   RowBox[{"[", "i", "]"}], "]"}], "[", 
                  RowBox[{"[", "2", "]"}], "]"}]}], ")"}], "^", "2"}], "/", 
              "2"}], "/", 
             RowBox[{"sigma", "^", "2"}]}]}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", 
           RowBox[{"Length", "[", "ptsBCol", "]"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"myQs", "[", 
        RowBox[{"x_", ",", "y_"}], "]"}], "=", 
       RowBox[{"\[Kappa]", " ", 
        SqrtBox[
         RowBox[{"n2", "[", 
          RowBox[{"x", ",", "y"}], "]"}]]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", "  ", 
       RowBox[{
       "Direct", " ", "sum", " ", "of", " ", "Gaussians", " ", "corresponds", 
        " ", "to", " ", "Monte", " ", "Carlo", " ", "Glauber"}], "  ", "*)"}],
       "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"mynG", "[", 
        RowBox[{"x_", ",", "y_"}], "]"}], " ", "=", 
       RowBox[{"Y", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"n1", "[", 
           RowBox[{"x", ",", "y"}], "]"}], "+", 
          RowBox[{"n2", "[", 
           RowBox[{"x", ",", "y"}], "]"}]}], ")"}]}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"myplot", "=", 
       RowBox[{"DensityPlot", "[", 
        RowBox[{
         RowBox[{"mynG", "[", 
          RowBox[{"x", ",", "y"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "xmin", ",", "xmax"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"y", ",", "ymin", ",", "ymax"}], "}"}], ",", 
         RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
         RowBox[{"ColorFunction", "\[Rule]", "\"\<SunsetColors\>\""}], ",", 
         RowBox[{"PlotLegends", "\[Rule]", "Automatic"}], ",", 
         RowBox[{"ImageSize", "\[Rule]", "300"}], ",", 
         RowBox[{
         "PlotLabel", "\[Rule]", 
          "\"\<\!\(TraditionalForm\`\[LeftAngleBracket]\*SuperscriptBox[\(dn\)\
, \(G\)]\\\ /\\\ \*SuperscriptBox[\(d\), \
\(2\)]x\[RightAngleBracket]\)\>\""}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Return", "[", 
       RowBox[{"{", 
        RowBox[{"n1", ",", "myQs", ",", "mynG", ",", "myplot"}], "}"}], "]"}],
       ";"}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
