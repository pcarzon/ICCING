Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"Qs", ",", "TR", ",", "nG"}], "}"}], "=", 
     RowBox[{"ReadTrento", "[", 
      RowBox[{"Random", "[", 
       RowBox[{"Integer", ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "24"}], "}"}]}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"TRplot", "=", 
     RowBox[{"ArrayPlot", "[", 
      RowBox[{
       RowBox[{"Transpose", "@", "TR"}], ",", 
       RowBox[{"PlotLabel", "\[Rule]", "\"\<Old\>\""}], ",", 
       RowBox[{"ColorFunction", "\[Rule]", "\"\<SunsetColors\>\""}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"TRfm", "=", 
     RowBox[{"Delete", "[", 
      RowBox[{
       RowBox[{"Import", "[", "\"\<ic6.dat\>\"", "]"}], ",", "1"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"TRfmplot", "=", 
     RowBox[{"ListDensityPlot", "[", 
      RowBox[{"TRfm", ",", 
       RowBox[{"ColorFunction", "\[Rule]", "\"\<SunsetColors\>\""}], ",", 
       RowBox[{"ImageSize", "\[Rule]", "300"}], ",", 
       RowBox[{"PlotLabel", "\[Rule]", "\"\<TR\>\""}], ",", 
       RowBox[{"AspectRatio", "\[Rule]", "1"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"newTRgrid", "=", 
     RowBox[{"ConstantArray", "[", 
      RowBox[{"0", ",", 
       RowBox[{"{", 
        RowBox[{"imax", ",", "jmax"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"newTRfmgrid", "=", 
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          SubscriptBox["#", 
           RowBox[{"\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]], 
          ",", 
          SubscriptBox["#", 
           RowBox[{"\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]], 
          ",", "0"}], "}"}], "&"}], ",", "TRfm"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Ethresh", "=", "0.05"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"len", "=", 
     RowBox[{
      RowBox[{"Length", "[", 
       RowBox[{"ArrayRules", "[", "TR", "]"}], "]"}], "-", "1"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"newlen", "=", 
     RowBox[{
      RowBox[{"Length", "[", 
       RowBox[{"ArrayRules", "[", 
        RowBox[{"SparseArray", "[", "newTRgrid", "]"}], "]"}], "]"}], "-", 
      "1"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Einitial", "=", 
     RowBox[{
      RowBox[{"Sum", "[", 
       RowBox[{
        SubscriptBox["TR", 
         RowBox[{"\[LeftDoubleBracket]", 
          RowBox[{"i", ",", "j"}], "\[RightDoubleBracket]"}]], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "imax"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "1", ",", "jmax"}], "}"}]}], "]"}], "*", "dx", "*",
       "dy"}]}], ";"}]}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"mymovie", "=", 
     RowBox[{"{", "}"}]}], ";"}], "*)"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", "\[IndentingNewLine]", "*)"}]], "Input",
 CellChangeTimes->{{3.7692752934525137`*^9, 3.7692753459985485`*^9}, {
