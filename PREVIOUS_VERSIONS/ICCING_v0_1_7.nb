Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Define", " ", "the", " ", "procedure", " ", "to", " ", "sample", " ", 
    "the", " ", "outcome", " ", "of", " ", "a", " ", "possible", " ", "gluon",
     " ", "splitting"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"RollFlavor", "[", "Qs_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "u", ",", "d", ",", "s", ",", "c", ",", "g", ",", "t", ",", 
        "charges"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"u", "=", 
        RowBox[{"\[Alpha]s", "*", 
         RowBox[{"up", "[", "Qs", "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"d", "=", 
        RowBox[{"\[Alpha]s", "*", 
         RowBox[{"down", "[", "Qs", "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"s", "=", 
        RowBox[{"\[Alpha]s", "*", 
         RowBox[{"strange", "[", "Qs", "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"c", "=", 
        RowBox[{"\[Alpha]s", "*", 
         RowBox[{"charm", "[", "Qs", "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"g", "=", 
        RowBox[{"1", "-", "u", "-", "d", "-", "s", "-", "c"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"t", "=", 
        RowBox[{"RandomReal", "[", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"0", "\[LessEqual]", "t", "\[LessEqual]", "g"}], ",", 
         RowBox[{"charges", "=", 
          RowBox[{"{", 
           RowBox[{"\"\<g\>\"", ",", "0", ",", "0", ",", "0", ",", "0"}], 
           "}"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"g", "<", "t", "\[LessEqual]", 
            RowBox[{"g", "+", "u"}]}], ",", 
           RowBox[{"charges", "=", 
            RowBox[{"{", 
             RowBox[{"\"\<u\>\"", ",", "0.0023", ",", 
              RowBox[{"1", "/", "3"}], ",", "0", ",", 
              RowBox[{"2", "/", "3"}]}], "}"}]}], ",", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"g", "+", "u"}], "<", "t", "\[LessEqual]", 
              RowBox[{"g", "+", "u", "+", "d"}]}], ",", 
             RowBox[{"charges", "=", 
              RowBox[{"{", 
               RowBox[{"\"\<d\>\"", ",", "0.0048", ",", 
                RowBox[{"1", "/", "3"}], ",", "0", ",", 
                RowBox[{
                 RowBox[{"-", "1"}], "/", "3"}]}], "}"}]}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"g", "+", "u", "+", "d"}], "<", "t", "\[LessEqual]", 
                RowBox[{"g", "+", "u", "+", "d", "+", "s"}]}], ",", 
               RowBox[{"charges", "=", 
                RowBox[{"{", 
                 RowBox[{"\"\<s\>\"", ",", "0.095", ",", 
                  RowBox[{"1", "/", "3"}], ",", 
                  RowBox[{"-", "1"}], ",", 
                  RowBox[{
                   RowBox[{"-", "1"}], "/", "3"}]}], "}"}]}], ",", 
               "\[IndentingNewLine]", 
               RowBox[{"charges", "=", 
                RowBox[{"{", 
                 RowBox[{"\"\<c\>\"", ",", "1.29", ",", 
                  RowBox[{"1", "/", "3"}], ",", "0", ",", 
                  RowBox[{"2", "/", "3"}]}], "}"}]}]}], "\[IndentingNewLine]",
               "]"}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]",
           "]"}]}], "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Return", "[", "charges", "]"}]}]}], "        ", 
     "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
   RowBox[{"(*", "  ", 
    RowBox[{
    "Returns", " ", "a", " ", "list", " ", "of", " ", "properties", " ", "of",
      " ", "the", " ", "selected", " ", 
     RowBox[{"particle", ":", "  ", 
      RowBox[{"{", 
