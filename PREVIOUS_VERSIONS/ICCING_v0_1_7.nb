                "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]], 
               "dy"}]}], "]"}], "<>", "\"\< fm}\>\""}], "]"}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"PrintTemporary", "[", 
