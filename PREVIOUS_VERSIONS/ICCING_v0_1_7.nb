Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Generate", " ", "an", " ", "initial", " ", "density", " ", "profile", " ",
     "for", " ", "the", " ", "collision"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"GenerateMCGlauber", "[", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "ptsACol", ",", "ptsBCol", ",", "n1", ",", "n2", ",", "myQs", ",", 
       "mynG", ",", "myplot"}], "}"}], " ", ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"status", "=", "\"\<Generating MC Glauber\>\""}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"ptsACol", ",", "ptsBCol"}], "}"}], " ", "=", " ", 
