   3.7693440022713194`*^9, 3.769344003222807*^9}, {3.7693451865986447`*^9, 
   3.7693451869078193`*^9}, {3.7693680046657963`*^9, 3.76936801947572*^9}, {
   3.769421499289549*^9, 3.7694214994457626`*^9}, {3.7694269014084535`*^9, 
