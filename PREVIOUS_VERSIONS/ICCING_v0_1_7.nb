Cell[CellGroupData[{

Cell["View Trento Input", "Subsubsection",
 CellChangeTimes->{{3.76925209951516*^9, 
  3.769252103050394*^9}},ExpressionUUID->"40cba2be-dad9-4b3f-b2d4-\
0932c721afb1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{
     "A", " ", "simple", " ", "routine", " ", "which", " ", "takes", " ", 
      "in", " ", "a", " ", "number", " ", "like", " ", "n"}], "=", "6"}], ",",
     " ", 
    RowBox[{
    "then", " ", "reads", " ", "in", " ", "the", " ", "three", " ", "files", 
     " ", 
     RowBox[{"ic6", ".", "dat"}]}], ",", " ", 
    RowBox[{"TA6", ".", "dat"}], ",", " ", 
    RowBox[{"and", " ", 
     RowBox[{"TB6", ".", "dat"}], " ", "corresponding", " ", "to", " ", 
     "TR"}], ",", " ", "TA", ",", " ", 
    RowBox[{"and", " ", "TB"}], ",", " ", 
    RowBox[{
    "and", " ", "prints", " ", "a", " ", "graphic", " ", "of", " ", "the", 
     " ", "event", " ", "so", " ", "you", " ", "can", " ", "see", " ", 
     "whether", " ", "it", " ", "looks", " ", 
     RowBox[{"right", "."}]}]}], " ", "\[IndentingNewLine]", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ViewTrento", "[", "num_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "mydata", ",", "myimax", ",", "myjmax", ",", "myTAfile", ",", 
       "myTBfile", ",", "myTRfile", ",", "myTA", ",", "mysparseTA", ",", 
       "myTB", ",", "mysparseTB", ",", "myTR", ",", "mysparseTR", ",", 
       "myEnergy", ",", "mysparseEnergy", ",", "myEtot", ",", "myplot", ",", 
       "mytitle"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"SetDirectory", "[", "TrentoInputDir", "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"myTAfile", "=", 
       RowBox[{"StringJoin", "[", 
        RowBox[{"\"\<TA\>\"", ",", 
         RowBox[{"ToString", "[", "num", "]"}], ",", "\"\<.dat\>\""}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"myTBfile", "=", 
       RowBox[{"StringJoin", "[", 
        RowBox[{"\"\<TB\>\"", ",", 
         RowBox[{"ToString", "[", "num", "]"}], ",", "\"\<.dat\>\""}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"myTRfile", "=", 
       RowBox[{"StringJoin", "[", 
        RowBox[{"\"\<ic\>\"", ",", 
         RowBox[{"ToString", "[", "num", "]"}], ",", "\"\<.dat\>\""}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"myTA", "=", 
       RowBox[{"Delete", "[", 
        RowBox[{
         RowBox[{"Import", "[", "myTAfile", "]"}], ",", "1"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"myTB", "=", 
       RowBox[{"Delete", "[", 
        RowBox[{
         RowBox[{"Import", "[", "myTBfile", "]"}], ",", "1"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"myTR", "=", 
       RowBox[{"Delete", "[", 
        RowBox[{
         RowBox[{"Import", "[", "myTRfile", "]"}], ",", "1"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"mydata", "=", 
       RowBox[{"Part", "[", 
        RowBox[{
         RowBox[{"Import", "[", "myTAfile", "]"}], ",", "1"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"imax", "=", 
       RowBox[{"Round", "@", 
        RowBox[{"Abs", "[", 
         RowBox[{"2", "*", 
          FractionBox[
           SubscriptBox["mydata", 
            RowBox[{"\[LeftDoubleBracket]", "5", "\[RightDoubleBracket]"}]], 
           SubscriptBox["mydata", 
            RowBox[{
            "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]]]}], 
         "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"jmax", "=", 
       RowBox[{"Round", "@", 
        RowBox[{"Abs", "[", 
         RowBox[{"2", "*", 
          FractionBox[
           SubscriptBox["mydata", 
