 CellLabel->
  "In[238]:=",ExpressionUUID->"c000f03b-e25d-40c4-9382-4e6af68980dc"],

Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"PrintTemporary", "[", 
     RowBox[{"Dynamic", "[", 
      RowBox[{"{", 
       RowBox[{"Ethresh", ",", "Eglue", ",", "Etot"}], "}"}], "]"}], "]"}], 
    ";", "\[IndentingNewLine]", 
    RowBox[{"PrintTemporary", "[", 
     RowBox[{"Dynamic", "[", 
      RowBox[{"Style", "[", 
       RowBox[{"mytext", ",", "mycolor"}], "]"}], "]"}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"PrintTemporary", "[", 
     RowBox[{"Dynamic", "[", 
      RowBox[{"\"\<Input Grid \>\"", "<>", 
       RowBox[{"ToString", "[", "len", "]"}], "<>", 
       "\"\< points, Output Grid \>\"", "<>", 
       RowBox[{"ToString", "[", "newlen", "]"}], "<>", "\"\< points\>\""}], 
      "]"}], "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"PrintTemporary", "[", 
     RowBox[{"Dynamic", "[", 
      RowBox[{"\"\<Input Energy \>\"", "<>", 
       RowBox[{"ToString", "[", "Einput", "]"}], "<>", 
       "\"\<, Output Energy \>\"", "<>", 
       RowBox[{"ToString", "[", "Eoutput", "]"}], "<>", "\"\<     \>\"", "<>", 
       RowBox[{"ToString", "[", 
        RowBox[{"Round", "[", 
         FractionBox[
          RowBox[{"100", "*", "Eoutput"}], "Einitial"], "]"}], "]"}], "<>", 
       "\"\<%\>\""}], "]"}], "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"PrintTemporary", "[", 
     RowBox[{"Dynamic", "[", 
      RowBox[{"\"\<Initial Energy \>\"", "<>", 
       RowBox[{"ToString", "[", "Einitial", "]"}], "<>", 
       "\"\<, Current Energy \>\"", "<>", 
       RowBox[{"ToString", "[", 
        RowBox[{"Einput", "+", "Eoutput"}], "]"}]}], "]"}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"PrintTemporary", "[", 
     RowBox[{"Dynamic", "[", "\[IndentingNewLine]", 
      RowBox[{"GraphicsGrid", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"{", "\[IndentingNewLine]", 
          RowBox[{"TRplot", ",", "\[IndentingNewLine]", "newplot"}], 
          "\[IndentingNewLine]", "}"}], "}"}], ",", 
        RowBox[{"ImageSize", "\[Rule]", "1000"}]}], "]"}], 
      "\[IndentingNewLine]", "]"}], "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"PrintTemporary", "[", 
     RowBox[{"Dynamic", "[", "\[IndentingNewLine]", 
      RowBox[{"GraphicsGrid", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"{", "\[IndentingNewLine]", 
          RowBox[{
          "NBplot", ",", "\[IndentingNewLine]", "NSplot", ",", 
           "\[IndentingNewLine]", "NQplot"}], "\[IndentingNewLine]", "}"}], 
         "}"}], ",", 
        RowBox[{"ImageSize", "\[Rule]", "1000"}]}], "]"}], 
      "\[IndentingNewLine]", "]"}], "]"}], ";"}], "*)"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"PrintTemporary", "[", 
     RowBox[{"Dynamic", "[", 
      RowBox[{"\"\<Input Energy \>\"", "<>", 
       RowBox[{"ToString", "[", "Einput", "]"}]}], "]"}], "]"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"PrintTemporary", "[", 
     RowBox[{"Dynamic", "[", 
      RowBox[{"\"\<Output Energy \>\"", "<>", 
       RowBox[{"ToString", "[", "Eoutput", "]"}]}], "]"}], "]"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"PrintTemporary", "[", 
     RowBox[{"Dynamic", "[", 
      RowBox[{
       RowBox[{"ToString", "[", 
        RowBox[{"Round", "[", 
         FractionBox[
          RowBox[{"100", "*", "Eoutput"}], "Einitial"], "]"}], "]"}], "<>", 
       "\"\<%\>\""}], "]"}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"mytest", "=", "True"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"While", "[", 
     RowBox[{"mytest", ","}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"While", "[", 
    RowBox[{
     RowBox[{"len", ">", "0"}], ",", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"ran", "=", 
       RowBox[{"RandomInteger", "[", 
        RowBox[{"{", 
         RowBox[{"1", ",", "len"}], "}"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"ranpt", "=", 
       SubscriptBox[
        RowBox[{"ArrayRules", "[", "TR", "]"}], 
        RowBox[{"\[LeftDoubleBracket]", 
         RowBox[{"ran", ",", "1"}], "\[RightDoubleBracket]"}]]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"circlist", "=", 
       RowBox[{"Flatten", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"ranpt", "+", 
            RowBox[{"{", 
             RowBox[{"i", ",", "j"}], "}"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"j", ",", 
             RowBox[{"-", "irad"}], ",", "irad"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", 
             RowBox[{"-", 
              RowBox[{"Round", "[", 
               SqrtBox[
                RowBox[{
                 SuperscriptBox["irad", "2"], "-", 
                 SuperscriptBox["j", "2"]}]], "]"}]}], ",", 
             RowBox[{"Round", "[", 
              SqrtBox[
               RowBox[{
                SuperscriptBox["irad", "2"], "-", 
                SuperscriptBox["j", "2"]}]], "]"}]}], "}"}]}], "]"}], ",", 
         "1"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Etot", "=", 
       RowBox[{
        RowBox[{"Sum", "[", 
         RowBox[{
          SubscriptBox["TR", 
           RowBox[{"\[LeftDoubleBracket]", 
            RowBox[{
             SubscriptBox["circlist", 
              RowBox[{"\[LeftDoubleBracket]", 
               RowBox[{"i", ",", "1"}], "\[RightDoubleBracket]"}]], ",", 
             SubscriptBox["circlist", 
              RowBox[{"\[LeftDoubleBracket]", 
               RowBox[{"i", ",", "2"}], "\[RightDoubleBracket]"}]]}], 
            "\[RightDoubleBracket]"}]], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", 
            RowBox[{"Length", "@", "circlist"}]}], "}"}]}], "]"}], "*", "dx", 
        "*", "dy"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Eglue", "=", 
       RowBox[{"RandomReal", "[", 
        RowBox[{"{", 
         RowBox[{"Ethresh", ",", "1"}], "}"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"myQs", "=", 
       RowBox[{"Mean", "[", 
        RowBox[{"Table", "[", 
         RowBox[{
          SubscriptBox["Qs", 
           RowBox[{"\[LeftDoubleBracket]", 
            RowBox[{
             SubscriptBox["circlist", 
              RowBox[{"\[LeftDoubleBracket]", 
               RowBox[{"i", ",", "1"}], "\[RightDoubleBracket]"}]], ",", 
             SubscriptBox["circlist", 
              RowBox[{"\[LeftDoubleBracket]", 
               RowBox[{"i", ",", "2"}], "\[RightDoubleBracket]"}]]}], 
            "\[RightDoubleBracket]"}]], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", 
            RowBox[{"Length", "@", "circlist"}]}], "}"}]}], "]"}], "]"}]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"result", "=", 
       RowBox[{"SplittingSample", "[", "myQs", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"flav", "=", 
       SubscriptBox["result", 
        RowBox[{"\[LeftDoubleBracket]", 
         RowBox[{"1", ",", "1"}], "\[RightDoubleBracket]"}]]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"\[Alpha]res", "=", 
       SubscriptBox["result", 
        RowBox[{"\[LeftDoubleBracket]", 
         RowBox[{"2", ",", "1"}], "\[RightDoubleBracket]"}]]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"m", "=", 
       SubscriptBox["result", 
        RowBox[{"\[LeftDoubleBracket]", 
         RowBox[{"1", ",", "2"}], "\[RightDoubleBracket]"}]]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"nB", "=", 
       SubscriptBox["result", 
        RowBox[{"\[LeftDoubleBracket]", 
         RowBox[{"1", ",", "3"}], "\[RightDoubleBracket]"}]]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"nS", "=", 
       SubscriptBox["result", 
        RowBox[{"\[LeftDoubleBracket]", 
         RowBox[{"1", ",", "4"}], "\[RightDoubleBracket]"}]]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"nQ", "=", 
       SubscriptBox["result", 
        RowBox[{"\[LeftDoubleBracket]", 
         RowBox[{"1", ",", "5"}], "\[RightDoubleBracket]"}]]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"\[CapitalDelta]i", "=", 
       RowBox[{"Round", "[", 
        FractionBox[
         SubscriptBox["result", 
          RowBox[{"\[LeftDoubleBracket]", 
           RowBox[{"2", ",", "2"}], "\[RightDoubleBracket]"}]], "dx"], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"\[CapitalDelta]j", "=", 
       RowBox[{"Round", "[", 
        FractionBox[
         SubscriptBox["result", 
          RowBox[{"\[LeftDoubleBracket]", 
           RowBox[{"2", ",", "3"}], "\[RightDoubleBracket]"}]], "dy"], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"IsQuark", "=", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"flav", "\[NotEqual]", "\"\<g\>\""}], ",", "True", ",", 
         "False"}], "]"}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"Which", "[", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{
         "If", " ", "the", " ", "enclosed", " ", "energy", " ", "is", " ", 
          "less", " ", "than", " ", "the", " ", "up", " ", "quark", " ", 
          "threshold"}], ",", " ", 
         RowBox[{
         "it", " ", "will", " ", "never", " ", "pair", " ", "produce"}]}], 
        " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Etot", "<", "Ethresh"}], ",", "\[IndentingNewLine]", "\t", 
        RowBox[{
         RowBox[{"mycolor", "=", "Red"}], ";", "\t", "\[IndentingNewLine]", 
         "\t", 
         RowBox[{"mytext", "=", 
          RowBox[{"\"\<Energy \>\"", "<>", 
           RowBox[{"ToString", "[", "Etot", "]"}], "<>", 
           "\"\< is below up quark threshold \>\"", "<>", 
           RowBox[{"ToString", "[", "Ethresh", "]"}]}]}], ";", "\t", 
         "\[IndentingNewLine]", "\t", 
         RowBox[{"For", "[", 
          RowBox[{
           RowBox[{"k", "=", "1"}], ",", 
           RowBox[{"k", "\[LessEqual]", 
            RowBox[{"Length", "[", "circlist", "]"}]}], ",", 
           RowBox[{"k", "++"}], ",", "\[IndentingNewLine]", "\t", 
           RowBox[{
            RowBox[{"ival", "=", 
             SubscriptBox["circlist", 
              RowBox[{"\[LeftDoubleBracket]", 
               RowBox[{"k", ",", "1"}], "\[RightDoubleBracket]"}]]}], ";", 
            "\[IndentingNewLine]", "\t", 
            RowBox[{"jval", "=", 
             SubscriptBox["circlist", 
              RowBox[{"\[LeftDoubleBracket]", 
               RowBox[{"k", ",", "2"}], "\[RightDoubleBracket]"}]]}], ";", 
            "\[IndentingNewLine]", "\t", 
            RowBox[{
             SubscriptBox["newTRgrid", 
              RowBox[{"\[LeftDoubleBracket]", 
               RowBox[{"ival", ",", "jval"}], "\[RightDoubleBracket]"}]], "+=", 
             SubscriptBox["TR", 
              RowBox[{"\[LeftDoubleBracket]", 
               RowBox[{"ival", ",", "jval"}], "\[RightDoubleBracket]"}]]}], 
            ";", "\[IndentingNewLine]", "\t", 
            RowBox[{
             SubscriptBox["TR", 
              RowBox[{"\[LeftDoubleBracket]", 
               RowBox[{"ival", ",", "jval"}], "\[RightDoubleBracket]"}]], "=",
              "0"}], ";"}]}], "\[IndentingNewLine]", "\t", "]"}], ";", 
         "\[IndentingNewLine]", "\t", 
         RowBox[{"Einput", "=", 
          RowBox[{
           RowBox[{"Sum", "[", 
            RowBox[{
             SubscriptBox["TR", 
              RowBox[{"\[LeftDoubleBracket]", 
               RowBox[{"i", ",", "j"}], "\[RightDoubleBracket]"}]], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "1", ",", "imax"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"j", ",", "1", ",", "jmax"}], "}"}]}], "]"}], "*", "dx",
            "*", "dy"}]}], ";", "\[IndentingNewLine]", "\t", 
         RowBox[{"Eoutput", "=", 
          RowBox[{
           RowBox[{"Sum", "[", 
            RowBox[{
             SubscriptBox["newTRgrid", 
              RowBox[{"\[LeftDoubleBracket]", 
               RowBox[{"i", ",", "j"}], "\[RightDoubleBracket]"}]], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "1", ",", "imax"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"j", ",", "1", ",", "jmax"}], "}"}]}], "]"}], "*", "dx",
            "*", "dy"}]}], ";"}], "\[IndentingNewLine]", "\t", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"TRplot", "=", 
           RowBox[{"MatrixPlot", "[", 
            RowBox[{
             RowBox[{"Transpose", "@", "TR"}], ",", 
             RowBox[{"PlotLabel", "\[Rule]", "\"\<Old\>\""}]}], "]"}]}], 
          ";"}], "*)"}], "\[IndentingNewLine]", "\t", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"newplot", "=", 
           RowBox[{"ArrayPlot", "[", 
            RowBox[{
             RowBox[{"Transpose", "@", "newTRgrid"}], ",", 
             RowBox[{"PlotLabel", "\[Rule]", "\"\<New\>\""}], ",", 
             RowBox[{"ColorFunction", "\[Rule]", "\"\<SunsetColors\>\""}]}], 
            "]"}]}], ";"}], "*)"}], "\[IndentingNewLine]", "\t", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"newplot", "=", 
           RowBox[{"MatrixPlot", "[", 
            RowBox[{
             RowBox[{"Transpose", "@", "newTRgrid"}], ",", 
             RowBox[{"PlotLabel", "\[Rule]", "\"\<New\>\""}]}], "]"}]}], 
          ";"}], "*)"}], "\[IndentingNewLine]", "\t", 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{"AppendTo", "[", 
           RowBox[{"mymovie", ",", 
            RowBox[{"GraphicsGrid", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"{", 
                RowBox[{"TRplot", ",", "newplot"}], "}"}], "}"}], ",", 
              RowBox[{"ImageSize", "\[Rule]", "1000"}]}], "]"}]}], "]"}], 
          ";"}], "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{
          "If", " ", "the", " ", "enclosed", " ", "energy", " ", "is", " ", 
           "not", " ", "enough", " ", "to", " ", "yield", " ", "the", " ", 
           "gluon", " ", "in", " ", "question"}], ",", " ", 
          RowBox[{"try", " ", "again"}]}], " ", "*)"}], "\[IndentingNewLine]",
         ",", 
        RowBox[{"Ethresh", "\[LessEqual]", "Etot", "<", "Eglue"}], ",", 
        "\[IndentingNewLine]", "\t", 
        RowBox[{
         RowBox[{"mycolor", "=", "Blue"}], ";", "\[IndentingNewLine]", "\t", 
         RowBox[{"mytext", "=", "\"\<Not Enough Energy for This Gluon\>\""}], 
         ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{
          "If", " ", "the", " ", "gluon", " ", "energy", " ", "is", " ", 
           "not", " ", "enough", " ", "to", " ", "pair", " ", "produce", " ", 
           "the", " ", "desired", " ", "quarks"}], ",", " ", 
          RowBox[{"try", " ", "again"}]}], " ", "*)"}], "\[IndentingNewLine]",
         ",", 
        RowBox[{"Eglue", "<", 
         RowBox[{"2", "m"}]}], ",", "\[IndentingNewLine]", "\t", 
        RowBox[{
         RowBox[{"mycolor", "=", "Blue"}], ";", "\[IndentingNewLine]", "\t", 
         RowBox[{"mytext", "=", 
          RowBox[{"\"\<Energy \>\"", "<>", 
           RowBox[{"ToString", "[", "Eglue", "]"}], "<>", 
           "\"\< is not enough to meet \>\"", "<>", "flav", "<>", 
           "\"\< quark threshold \>\"", "<>", 
           RowBox[{"ToString", "[", 
            RowBox[{"2", "m"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", "\t",
         "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
         "If", " ", "there", " ", "is", " ", "enough", " ", "energy", " ", 
          "to", " ", "produce", " ", "the", " ", "given", " ", "pair", " ", 
          "then", " ", "follow", " ", "the", " ", "splitting", " ", 
          "algorithm"}], " ", "*)"}], "\[IndentingNewLine]", ",", 
        RowBox[{
         RowBox[{"2", "m"}], " ", "\[LessEqual]", "Eglue", "\[LessEqual]", 
         "Etot"}], ",", "\[IndentingNewLine]", "\t", 
        RowBox[{
         RowBox[{"mycolor", "=", "Green"}], ";", "\[IndentingNewLine]", "\t", 
         RowBox[{"If", "[", 
          RowBox[{"IsQuark", ",", "\[IndentingNewLine]", "\t\t", 
           RowBox[{
            RowBox[{"mytext", "=", 
             RowBox[{
             "\"\<Splits into \>\"", "<>", "flav", "<>", 
              "\"\< quarks\>\""}]}], ";", "\[IndentingNewLine]", "\t\t", 
            RowBox[{"For", "[", 
             RowBox[{
              RowBox[{"k", "=", "1"}], ",", 
              RowBox[{"k", "\[LessEqual]", 
               RowBox[{"Length", "[", "circlist", "]"}]}], ",", 
              RowBox[{"k", "++"}], ",", "\[IndentingNewLine]", "\t\t\t", 
              RowBox[{
               RowBox[{"ival", "=", 
                SubscriptBox["circlist", 
                 RowBox[{"\[LeftDoubleBracket]", 
                  RowBox[{"k", ",", "1"}], "\[RightDoubleBracket]"}]]}], ";", 
               "\[IndentingNewLine]", "\t\t\t", 
               RowBox[{"jval", "=", 
                SubscriptBox["circlist", 
                 RowBox[{"\[LeftDoubleBracket]", 
                  RowBox[{"k", ",", "2"}], "\[RightDoubleBracket]"}]]}], ";", 
               "\[IndentingNewLine]", "\t\t\t", 
               RowBox[{
                SubscriptBox["TR", 
                 RowBox[{"\[LeftDoubleBracket]", 
                  RowBox[{"ival", ",", "jval"}], "\[RightDoubleBracket]"}]], "-=", 
                RowBox[{
                 FractionBox["Eglue", "Etot"], 
                 SubscriptBox["TR", 
                  RowBox[{"\[LeftDoubleBracket]", 
                   RowBox[{"ival", ",", "jval"}], 
                   "\[RightDoubleBracket]"}]]}]}], ";"}]}], 
             "\[IndentingNewLine]", "\t\t", "]"}], ";", "\[IndentingNewLine]",
             "\t\t", 
            RowBox[{"qpt", "=", 
             RowBox[{"ranpt", "+", 
              RowBox[{"{", 
               RowBox[{"\[CapitalDelta]i", ",", "\[CapitalDelta]j"}], 
               "}"}]}]}], ";", "\[IndentingNewLine]", "\t\t", 
            RowBox[{"qbarpt", "=", 
             RowBox[{"ranpt", "-", 
              RowBox[{"{", 
               RowBox[{"\[CapitalDelta]i", ",", "\[CapitalDelta]j"}], 
               "}"}]}]}], ";", "\[IndentingNewLine]", "\t\t", 
            RowBox[{"qcirclist", "=", 
             RowBox[{"Flatten", "[", 
              RowBox[{
               RowBox[{"Table", "[", 
                RowBox[{
                 RowBox[{"qpt", "+", 
                  RowBox[{"{", 
                   RowBox[{"i", ",", "j"}], "}"}]}], ",", 
                 RowBox[{"{", 
                  RowBox[{"j", ",", 
                   RowBox[{"-", "qirad"}], ",", "qirad"}], "}"}], ",", 
                 RowBox[{"{", 
                  RowBox[{"i", ",", 
                   RowBox[{"-", 
                    RowBox[{"Round", "[", 
                    SqrtBox[
                    RowBox[{
                    SuperscriptBox["qirad", "2"], "-", 
                    SuperscriptBox["j", "2"]}]], "]"}]}], ",", 
                   RowBox[{"Round", "[", 
                    SqrtBox[
                    RowBox[{
                    SuperscriptBox["qirad", "2"], "-", 
                    SuperscriptBox["j", "2"]}]], "]"}]}], "}"}]}], "]"}], ",",
                "1"}], "]"}]}], ";", "\[IndentingNewLine]", "\t\t", 
            RowBox[{"qbarcirclist", "=", 
             RowBox[{"Flatten", "[", 
              RowBox[{
               RowBox[{"Table", "[", 
                RowBox[{
                 RowBox[{"qbarpt", "+", 
                  RowBox[{"{", 
                   RowBox[{"i", ",", "j"}], "}"}]}], ",", 
                 RowBox[{"{", 
                  RowBox[{"j", ",", 
                   RowBox[{"-", "qirad"}], ",", "qirad"}], "}"}], ",", 
                 RowBox[{"{", 
