             RowBox[{"{", 
              RowBox[{"\[Epsilon]3", ",", " ", "\[Psi]3"}], "}"}]}], " ", 
            "}"}]}], " ", "*)"}], "\[IndentingNewLine]", ",", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
          "Print", "[", 
           "\"\<Empty matrix encountered; cannot compute eccentricities\>\"", 
