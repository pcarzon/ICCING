Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"If", " ", "called", " ", "with", " ", "one", " ", "argument"}], 
    ",", " ", 
    RowBox[{
     RowBox[{"a", " ", "number", " ", "like", " ", "n"}], "=", "6"}], ",", 
