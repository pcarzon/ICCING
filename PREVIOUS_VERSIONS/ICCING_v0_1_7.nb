      RowBox[{"(*", " ", 
       RowBox[{"Quark", " ", "radius"}], " ", "*)"}], "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "These", " ", "are", " ", "variables", " ", "to", " ", "monitor", " ", 
        "the", " ", "progress", " ", "through", " ", "the", " ", 
        "algorithm"}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"len", "=", 
       RowBox[{
        RowBox[{"Length", "[", 
         RowBox[{"ArrayRules", "[", "myEN", "]"}], "]"}], "-", "1"}]}], ";", 
      "    ", 
      RowBox[{"(*", " ", 
       RowBox[{
       "Number", " ", "of", " ", "points", " ", "with", " ", "nonzero", " ", 
        "energy", " ", "density", " ", "in", " ", "the", " ", "input", " ", 
        "array"}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"Einitial", "=", 
       RowBox[{
        RowBox[{"Sum", "[", 
         RowBox[{
          SubscriptBox["myEN", 
           RowBox[{"\[LeftDoubleBracket]", 
            RowBox[{"i", ",", "j"}], "\[RightDoubleBracket]"}]], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "imax"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", "1", ",", "jmax"}], "}"}]}], "]"}], "*", 
        "\[Tau]0", "*", "dx", "*", "dy"}]}], ";", "  ", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{
        "Total", " ", "energy", " ", "contained", " ", "in", " ", "the", " ", 
         "input", " ", "array"}], ",", " ", 
        RowBox[{
        "in", " ", "GeV", " ", "per", " ", "unit", " ", "rapidity"}]}], " ", 
       "*)"}], "\[IndentingNewLine]", 
      RowBox[{"Einput", "=", "Einitial"}], ";", "  ", 
      RowBox[{"(*", " ", 
       RowBox[{
       "Total", " ", "energy", " ", "which", " ", "has", " ", "not", " ", 
