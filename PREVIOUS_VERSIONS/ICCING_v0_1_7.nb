             RowBox[{"xmin", "+", 
              RowBox[{
               SubscriptBox["ranpt", 
                RowBox[{
                "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]], 
               "dx"}]}], "]"}], "<>", "\"\< fm, \>\"", "<>", 
            RowBox[{"ToString", "[", 
