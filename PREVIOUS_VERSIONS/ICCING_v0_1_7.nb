         RowBox[{"Einput", "=", 
          RowBox[{
           RowBox[{"Sum", "[", 
            RowBox[{
             SubscriptBox["TR", 
              RowBox[{"\[LeftDoubleBracket]", 
               RowBox[{"i", ",", "j"}], "\[RightDoubleBracket]"}]], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "1", ",", "imax"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"j", ",", "1", ",", "jmax"}], "}"}]}], "]"}], "*", "dx",
            "*", "dy"}]}], ";", "\[IndentingNewLine]", "\t", 
         RowBox[{"Eoutput", "=", 
          RowBox[{
           RowBox[{"Sum", "[", 
            RowBox[{
             SubscriptBox["newTRgrid", 
              RowBox[{"\[LeftDoubleBracket]", 
               RowBox[{"i", ",", "j"}], "\[RightDoubleBracket]"}]], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "1", ",", "imax"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"j", ",", "1", ",", "jmax"}], "}"}]}], "]"}], "*", "dx",
            "*", "dy"}]}], ";"}]}], "\[IndentingNewLine]", "\t", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{"AppendTo", "[", 
          RowBox[{"mymovie", ",", 
           RowBox[{"GraphicsGrid", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"{", 
