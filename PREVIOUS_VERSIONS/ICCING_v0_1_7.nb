Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Define", " ", "the", " ", "procedure", " ", "to", " ", "sample", " ", 
    "the", " ", "redistribution", " ", "of", " ", "a", " ", "possible", " ", 
    "gluon", " ", "splitting"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"SplittingSample", "[", "Qs_", "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"charges", ",", "m", ",", "IsQuark", ",", 
       RowBox[{"o", "=", 
        RowBox[{"{", "}"}]}], ",", "r", ",", "y", ",", "\[Alpha]temp", ",", 
       RowBox[{"rfinal", "=", "\"\<\>\""}], ",", 
       RowBox[{"\[Phi]", "=", 
        RowBox[{"RandomReal", "[", 
         RowBox[{"{", 
          RowBox[{"0", ",", 
           RowBox[{"2", "\[Pi]"}]}], "}"}], "]"}]}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"charges", "=", 
       RowBox[{"RollFlavor", "[", "Qs", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"m", "=", 
       SubscriptBox["charges", 
        RowBox[{"\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"\[Alpha]temp", "=", 
       RowBox[{"RandomReal", "[", 
        RowBox[{"{", 
         RowBox[{"\[Alpha]min", ",", 
          RowBox[{"1", "-", "\[Alpha]min"}]}], "}"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"IsQuark", "=", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          SubscriptBox["charges", 
           RowBox[{"\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]], 
          "\[NotEqual]", "\"\<g\>\""}], ",", "True", ",", "False"}], "]"}]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{"IsQuark", ",", "\[IndentingNewLine]", 
        RowBox[{"While", "[", 
         RowBox[{
          RowBox[{"rfinal", "\[Equal]", "\"\<\>\""}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"r", " ", "=", " ", 
            RowBox[{"RandomReal", "[", 
             RowBox[{"{", 
              RowBox[{"0", ",", "rmax"}], "}"}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"y", " ", "=", " ", 
            RowBox[{"RandomReal", "[", "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"y", "<", 
              RowBox[{
               RowBox[{"corr", "[", 
                RowBox[{"r", ",", "\[Alpha]temp", ",", "m", ",", "Qs"}], 
                "]"}], "/", 
               RowBox[{"(", 
                RowBox[{"1.2", "*", 
                 FractionBox[
                  RowBox[{
                   SuperscriptBox["Qs", "2"], " ", 
                   SuperscriptBox[
                    RowBox[{"(", 
                    RowBox[{"1", "-", 
                    RowBox[{"2", " ", "\[Alpha]temp"}], "+", 
                    RowBox[{"2", " ", 
                    SuperscriptBox["\[Alpha]temp", "2"]}]}], ")"}], "2"]}], 
                  RowBox[{"32", " ", 
                   SuperscriptBox["\[Pi]", "2"]}]]}], ")"}]}]}], ",", 
             RowBox[{"rfinal", "=", "r"}]}], "]"}], ";"}]}], 
         "\[IndentingNewLine]", "]"}], ",", 
        RowBox[{
         RowBox[{"Return", "[", 
          RowBox[{"{", 
           RowBox[{"charges", ",", 
            RowBox[{"{", 
             RowBox[{"1", ",", "0", ",", "0"}], "}"}]}], "}"}], "]"}], 
         ";"}]}], "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Return", "[", 
       RowBox[{"{", 
        RowBox[{"charges", ",", 
         RowBox[{"{", 
          RowBox[{"\[Alpha]temp", ",", 
           RowBox[{"rfinal", " ", 
            RowBox[{"Cos", "[", "\[Phi]", "]"}]}], ",", 
           RowBox[{"rfinal", " ", 
            RowBox[{"Sin", "[", "\[Phi]", "]"}]}]}], "}"}]}], "}"}], "]"}], 
      ";"}]}], "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{
      RowBox[{
      "Returns", " ", "the", " ", "charges", " ", "of", " ", "the", " ", 
       "selected", " ", "flavor"}], ",", " ", 
      RowBox[{
      "the", " ", "fraction", " ", "of", " ", "energy", " ", "being", " ", 
       "redistributed"}], ",", " ", 
      RowBox[{"and", " ", "the", " ", 
       RowBox[{"displacement", ":", "  ", 
        RowBox[{"{", " ", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"f", ",", "m", ",", "b", ",", "s", ",", "q"}], "}"}], " ", 
          ",", " ", 
          RowBox[{"{", 
           RowBox[{
           "\[Alpha]", ",", "\[CapitalDelta]x", ",", "\[CapitalDelta]y"}], 
           "}"}]}], " ", "}"}]}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
    "]"}], "  "}]}]], "Input",
 CellChangeTimes->{{3.768234724840887*^9, 3.768234755052925*^9}, {
