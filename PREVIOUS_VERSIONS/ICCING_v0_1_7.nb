Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Tabulate", " ", "all", " ", "eccentricities", " ", "for", " ", "writing", 
    " ", "to", " ", "file"}], " ", "*)"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"discEcc", "[", 
     RowBox[{
     "myEn_", ",", "myU_", ",", "myUbar_", ",", "myD_", ",", "myDbar_", ",", 
      "myS_", ",", "mySbar_", ",", "myC_", ",", "myCbar_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "\[Epsilon]En", ",", "\[Epsilon]U", ",", "\[Epsilon]Ubar", ",", 
        "\[Epsilon]D", ",", "\[Epsilon]Dbar", ",", "\[Epsilon]S", ",", 
        "\[Epsilon]Sbar", ",", "\[Epsilon]C", ",", "\[Epsilon]Cbar"}], "}"}], 
      ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"status", "=", "\"\<Calculating eccentricities\>\""}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"\[Epsilon]En", "=", 
        RowBox[{"Prepend", "[", 
         RowBox[{
          SubscriptBox[
           RowBox[{"eccDisc", "[", "myEn", "]"}], 
           RowBox[{"\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]], 
          ",", "\"\<entropy\>\""}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"\[Epsilon]U", "=", 
        RowBox[{"Prepend", "[", 
         RowBox[{
          SubscriptBox[
           RowBox[{"eccDisc", "[", "myU", "]"}], 
           RowBox[{"\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]], 
          ",", "\"\<up\>\""}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"\[Epsilon]Ubar", "=", 
        RowBox[{"Prepend", "[", 
         RowBox[{
          SubscriptBox[
           RowBox[{"eccDisc", "[", "myUbar", "]"}], 
           RowBox[{"\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]], 
          ",", "\"\<ubar\>\""}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"\[Epsilon]D", "=", 
        RowBox[{"Prepend", "[", 
         RowBox[{
          SubscriptBox[
           RowBox[{"eccDisc", "[", "myD", "]"}], 
           RowBox[{"\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]], 
          ",", "\"\<down\>\""}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"\[Epsilon]Dbar", "=", 
