Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"When", " ", "called", " ", "with", " ", "2", " ", "arguments"}], 
    ",", " ", 
    RowBox[{
    "this", " ", "routine", " ", "reads", " ", "in", " ", "the", " ", 
     "relevant", " ", "files", " ", "for", " ", "the", " ", "TB", " ", 
     "profile", " ", "and", " ", "TR", " ", "profile", " ", "and", " ", 
     "uses", " ", "them", " ", "to", " ", "construct", " ", "the", " ", 
     "sparse", " ", "arrays", " ", "for", " ", "Qs"}], ",", " ", 
    RowBox[{"the", " ", "energy", " ", "density"}], ",", " ", 
    RowBox[{
    "and", " ", "a", " ", "discretezed", " ", "energy", " ", "density", " ", 
     "used", " ", "as", " ", "a", " ", "proxy", " ", "for", " ", "the", " ", 
     "number", " ", "of", " ", "gluons"}]}], "\[IndentingNewLine]", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ReadTrento", "[", 
    RowBox[{"TBFile_", ",", "TRFile_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "mytb", ",", "mytr", ",", "myQsgrid", ",", "mysparseQs", ",", 
       "mytrgrid", ",", "mysparsetr"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"mytb", "=", 
       RowBox[{"Import", "[", "TBFile", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"mytr", "=", 
       RowBox[{"Import", "[", "TRFile", "]"}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "eventnum", ",", "dx", ",", "dy", ",", "Stot", ",", "xmin", ",", 
         "ymin"}], "}"}], "=", 
       SubscriptBox["mytb", 
        RowBox[{"\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"PrintTemporary", "[", 
       RowBox[{"\"\<Processing TRENTO Event #\>\"", "<>", 
        RowBox[{"ToString", "[", "eventnum", "]"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"imax", "=", 
       RowBox[{"Round", "@", 
        RowBox[{"Abs", "[", 
         RowBox[{"2", "*", 
          FractionBox["xmin", "dx"]}], "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"jmax", "=", 
       RowBox[{"Round", "@", 
        RowBox[{"Abs", "[", 
         RowBox[{"2", "*", 
          FractionBox["ymin", "dy"]}], "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"myQsgrid", "=", 
       RowBox[{"Map", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            FractionBox[
             RowBox[{
              SubscriptBox["#", 
               RowBox[{
               "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]], "-", 
              "xmin"}], "dx"], ",", 
            FractionBox[
             RowBox[{
              SubscriptBox["#", 
               RowBox[{
               "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]], "-", 
              "ymin"}], "dy"], ",", 
            RowBox[{"\[Kappa]", "*", 
             SqrtBox[
              SubscriptBox["#", 
               RowBox[{
               "\[LeftDoubleBracket]", "3", "\[RightDoubleBracket]"}]]]}]}], 
           "}"}], "&"}], ",", 
         RowBox[{"Delete", "[", 
          RowBox[{"mytb", ",", "1"}], "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"mysparseQs", "=", 
       RowBox[{"SparseArray", "[", 
        RowBox[{
         RowBox[{"Map", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"Round", "[", 
                SubscriptBox["#", 
                 RowBox[{
                 "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]], 
                "]"}], ",", 
               RowBox[{"Round", "[", 
                SubscriptBox["#", 
                 RowBox[{
                 "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]], 
                "]"}]}], "}"}], "\[Rule]", 
             SubscriptBox["#", 
              RowBox[{
              "\[LeftDoubleBracket]", "3", "\[RightDoubleBracket]"}]]}], 
            "&"}], ",", "myQsgrid"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"imax", ",", "jmax"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"mytrgrid", "=", 
       RowBox[{"Map", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            FractionBox[
             RowBox[{
              SubscriptBox["#", 
               RowBox[{
               "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]], "-", 
              "xmin"}], "dx"], ",", 
            FractionBox[
             RowBox[{
              SubscriptBox["#", 
               RowBox[{
               "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]], "-", 
              "ymin"}], "dy"], ",", 
            SubscriptBox["#", 
             RowBox[{
             "\[LeftDoubleBracket]", "3", "\[RightDoubleBracket]"}]]}], "}"}],
           "&"}], ",", 
         RowBox[{"Delete", "[", 
          RowBox[{"mytr", ",", "1"}], "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"mysparsetr", "=", 
       RowBox[{"SparseArray", "[", 
        RowBox[{
         RowBox[{"Map", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"Round", "[", 
                SubscriptBox["#", 
                 RowBox[{
                 "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]], 
                "]"}], ",", 
               RowBox[{"Round", "[", 
                SubscriptBox["#", 
                 RowBox[{
                 "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]], 
                "]"}]}], "}"}], "\[Rule]", 
             SubscriptBox["#", 
              RowBox[{
              "\[LeftDoubleBracket]", "3", "\[RightDoubleBracket]"}]]}], 
            "&"}], ",", "mytrgrid"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"imax", ",", "jmax"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Return", "[", 
       RowBox[{"{", 
        RowBox[{"mysparseQs", ",", "mysparsetr"}], "}"}], "]"}], ";"}]}], 
    "\[IndentingNewLine]", "]"}]}]}]], "Input",
