Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[Epsilon]1in", ",", "\[Epsilon]2in", ",", "\[Epsilon]3in"}], 
     "}"}], "=", 
    SubscriptBox[
     RowBox[{"eccDisc", "[", "initTR", "]"}], 
     RowBox[{"\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]]}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[Epsilon]1out", ",", "\[Epsilon]2out", ",", "\[Epsilon]3out"}],
      "}"}], "=", 
    SubscriptBox[
     RowBox[{"eccDisc", "[", "newTRgrid", "]"}], 
     RowBox[{"\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]]}], 
   "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     FractionBox[
      RowBox[{"\[Epsilon]2out", "-", "\[Epsilon]2in"}], "\[Epsilon]2in"], ",", 
     FractionBox[
      RowBox[{"\[Epsilon]3out", "-", "\[Epsilon]3in"}], "\[Epsilon]3in"]}], 
    "}"}], "\[IndentingNewLine]", 
   RowBox[{"GraphicsGrid", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"MatrixPlot", "[", 
          RowBox[{
           RowBox[{"Transpose", "@", "initTR"}], ",", 
           RowBox[{"PlotLabel", "\[Rule]", "\"\<Original\>\""}]}], "]"}], ",",
          "\[IndentingNewLine]", 
         RowBox[{"MatrixPlot", "[", 
          RowBox[{
           RowBox[{"Transpose", "@", "newTRgrid"}], ",", 
           RowBox[{"PlotLabel", "\[Rule]", "\"\<Modified\>\""}]}], "]"}]}], 
        "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"ListPlot3D", "[", 
          RowBox[{
           RowBox[{"Transpose", "@", "initTR"}], ",", 
           RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
           RowBox[{"PlotLabel", "\[Rule]", "\"\<Original\>\""}]}], "]"}], ",",
          "\[IndentingNewLine]", 
         RowBox[{"ListPlot3D", "[", 
          RowBox[{
           RowBox[{"Transpose", "@", "newTRgrid"}], ",", 
           RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
           RowBox[{"PlotLabel", "\[Rule]", "\"\<Modified\>\""}]}], "]"}]}], 
        "\[IndentingNewLine]", "}"}]}], "}"}], ",", 
     RowBox[{"ImageSize", "\[Rule]", "900"}]}], "]"}]}], "*)"}]], "Input",
