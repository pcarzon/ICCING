Cell[BoxData[
 RowBox[{
  RowBox[{"ConvertTrento", "[", "inTR_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"myEOSfile", ",", "myEOS", ",", "myentropy", ",", "myenergy"}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"SetDirectory", "[", "EOSInputDir", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"myEOSfile", "=", 
      RowBox[{"Drop", "[", 
       RowBox[{
        RowBox[{"Import", "[", "EOSInputFile", "]"}], ",", "EOSOmitLines"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"myEOS", "=", 
      RowBox[{"Interpolation", "[", 
       RowBox[{"Map", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            SubscriptBox["#", 
             RowBox[{
             "\[LeftDoubleBracket]", "EOSSCol", "\[RightDoubleBracket]"}]], 
            ",", 
            SubscriptBox["#", 
             RowBox[{
             "\[LeftDoubleBracket]", "EOSECol", "\[RightDoubleBracket]"}]]}], 
           "}"}], "&"}], ",", "myEOSfile"}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"myentropy", "=", 
      RowBox[{"aTrento", "*", "inTR"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"myenergy", "=", 
      RowBox[{"SparseArray", "[", 
       RowBox[{
        RowBox[{"Map", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            SubscriptBox["#", 
             RowBox[{"\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]], 
            "\[Rule]", 
            RowBox[{"Chop", "[", 
             RowBox[{
              RowBox[{"myEOS", "[", 
               SubscriptBox["#", 
                RowBox[{
                "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]], 
               "]"}], ",", "Echop"}], "]"}]}], "&"}], ",", 
          RowBox[{"Drop", "[", 
           RowBox[{
            RowBox[{"ArrayRules", "[", "myentropy", "]"}], ",", 
            RowBox[{"-", "1"}]}], "]"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"imax", ",", "jmax"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Return", "[", "myenergy", "]"}], ";"}]}], "\[IndentingNewLine]",
    "]"}]}]], "Input",
