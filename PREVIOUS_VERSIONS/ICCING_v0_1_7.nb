    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"newTRgrid", "=", 
     RowBox[{"ConstantArray", "[", 
      RowBox[{"0", ",", 
       RowBox[{"{", 
        RowBox[{"imax", ",", "jmax"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"len", "=", 
     RowBox[{
      RowBox[{"Length", "[", 
       RowBox[{"ArrayRules", "[", "TR", "]"}], "]"}], "-", "1"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"newlen", "=", 
     RowBox[{
      RowBox[{"Length", "[", 
       RowBox[{"ArrayRules", "[", 
        RowBox[{"SparseArray", "[", "newTRgrid", "]"}], "]"}], "]"}], "-", 
      "1"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Einitial", "=", 
     RowBox[{
      RowBox[{"Sum", "[", 
       RowBox[{
        SubscriptBox["TR", 
