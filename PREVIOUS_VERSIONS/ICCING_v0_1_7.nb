    RowBox[{"nuclear", " ", "saturation", " ", "density", " ", "in", " ", 
     RowBox[{"fm", "^", 
      RowBox[{"{", 
       RowBox[{"-", "3"}], "}"}]}]}]},
   {"Rn", 
    RowBox[{"radius", " ", "in", " ", "fm", " "}]},
   {"d", 
    RowBox[{"thickness", " ", "in", " ", "fm"}]},
   {"sigmann", 
    RowBox[{
     RowBox[{
     "nucleon", " ", "nucleon", " ", "cross", " ", "section", " ", "in", " ", 
      RowBox[{"millibarn", " ", "--"}], " ", "1", " ", 
      RowBox[{"fm", "^", "2"}]}], " ", "=", " ", 
     RowBox[{"10", " ", 
      RowBox[{"mb", " ", "--"}], " ", "used", " ", "for", " ", "collision", 
      " ", "detection"}]}]},
   {"bmin", 
    RowBox[{
    "minimum", " ", "impact", " ", "parameter", " ", "to", " ", "be", " ", 
