             RowBox[{"InputForm", "@", "Einput"}], "]"}], "<>", 
            "\"\< GeV per unit rapidity\>\""}], "]"}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"PrintTemporary", "[", 
          RowBox[{"Dynamic", "[", 
           RowBox[{"\"\<Output Energy \>\"", "<>", 
            RowBox[{"ToString", "[", 
             RowBox[{"InputForm", "@", "Eoutput"}], "]"}], "<>", 
            "\"\< GeV per unit rapidity\>\""}], "]"}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"PrintTemporary", "[", 
          RowBox[{"Dynamic", "[", 
           RowBox[{"\"\<len =\>\"", "<>", 
