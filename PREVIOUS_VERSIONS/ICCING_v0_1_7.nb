   {"Y", 
    RowBox[{
     RowBox[{"rapidity", " ", "--"}], " ", "overall", " ", "scale", " ", 
     "factor", " ", "determining", " ", "the", " ", "number", " ", "of", " ", 
     "gluons", " ", "produced"}]},
   {"dx", 
    RowBox[{"x", " ", "grid", " ", "spacing", " ", "in", " ", "fm"}]},
   {"dy", 
