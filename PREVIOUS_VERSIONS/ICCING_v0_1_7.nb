Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{
   RowBox[{
    RowBox[{"rad", "=", "0.25"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"qrad", "=", "0.25"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Ethresh", "=", "0.05"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"irad", "=", 
     RowBox[{"Round", "[", 
      FractionBox["rad", "dx"], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"qirad", "=", 
     RowBox[{"Round", "[", 
      FractionBox["qrad", "dx"], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"Qs", ",", "TR", ",", "nG"}], "}"}], "=", 
     RowBox[{"ReadTrento", "[", 
      RowBox[{"Random", "[", 
       RowBox[{"Integer", ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "24"}], "}"}]}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"initTR", "=", "TR"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"TRplot", "=", 
      RowBox[{"MatrixPlot", "[", 
       RowBox[{
        RowBox[{"Transpose", "@", "TR"}], ",", 
        RowBox[{"PlotLabel", "\[Rule]", "\"\<Old\>\""}]}], "]"}]}], ";"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"newTRgrid", "=", 
     RowBox[{"ConstantArray", "[", 
      RowBox[{"0", ",", 
       RowBox[{"{", 
        RowBox[{"imax", ",", "jmax"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"NewNBGrid", "=", 
     RowBox[{"ConstantArray", "[", 
      RowBox[{"0", ",", 
       RowBox[{"{", 
        RowBox[{"imax", ",", "jmax"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"NewNSGrid", "=", 
     RowBox[{"ConstantArray", "[", 
      RowBox[{"0", ",", 
       RowBox[{"{", 
        RowBox[{"imax", ",", "jmax"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"NewNQGrid", "=", 
     RowBox[{"ConstantArray", "[", 
      RowBox[{"0", ",", 
       RowBox[{"{", 
        RowBox[{"imax", ",", "jmax"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"len", "=", 
     RowBox[{
      RowBox[{"Length", "[", 
       RowBox[{"ArrayRules", "[", "TR", "]"}], "]"}], "-", "1"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"newlen", "=", 
     RowBox[{
      RowBox[{"Length", "[", 
       RowBox[{"ArrayRules", "[", 
        RowBox[{"SparseArray", "[", "newTRgrid", "]"}], "]"}], "]"}], "-", 
      "1"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Einitial", "=", 
     RowBox[{
      RowBox[{"Sum", "[", 
       RowBox[{
        SubscriptBox["TR", 
         RowBox[{"\[LeftDoubleBracket]", 
          RowBox[{"i", ",", "j"}], "\[RightDoubleBracket]"}]], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "imax"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "1", ",", "jmax"}], "}"}]}], "]"}], "*", "dx", "*",
       "dy"}]}], ";"}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"mymovie", "=", 
     RowBox[{"{", "}"}]}], ";"}], "*)"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", "\[IndentingNewLine]", "*)"}]], "Input",
 CellChangeTimes->{{3.7692752934525137`*^9, 3.7692753459985485`*^9}, {
   3.769275382476861*^9, 3.769275448640077*^9}, {3.769275725175911*^9, 
   3.769275727929392*^9}, {3.7692774971820974`*^9, 3.7692775154581957`*^9}, {
   3.769292409054511*^9, 3.7692924304316144`*^9}, {3.7692940983324285`*^9, 
   3.769294098492262*^9}, {3.7692949258412013`*^9, 3.7692949293537455`*^9}, {
   3.769296261992112*^9, 3.7692962667798014`*^9}, {3.769338902101329*^9, 
