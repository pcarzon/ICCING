Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{"(*", " ", 
   RowBox[{"Define", " ", "the", " ", "collision", " ", "detection", " ", 
    RowBox[{"algorithm", " ", "--"}], " ", "uses", " ", "hard", " ", "sphere",
     " ", "overlap", " ", "to", " ", "determine", " ", "wounded", " ", 
    "nucleons"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"distance", "[", 
       RowBox[{"pt1_", ",", "pt2_"}], "]"}], " ", "=", " ", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"pt1", "-", "pt2"}], ")"}], ".", 
        RowBox[{"(", 
         RowBox[{"pt1", "-", "pt2"}], ")"}]}], "]"}]}], ";"}], 
    "\[IndentingNewLine]", 
    RowBox[{"generateDist", "[", "b_", "]"}]}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "R", ",", "cT", ",", "F", ",", "pts1", ",", "pts2", ",", "colList1", 
       ",", "colList2", ",", "i", ",", "j", ",", "pts1Col", ",", "pts2Col"}], 
      "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"R", " ", "=", 
       RowBox[{"rejectionSample", "[", "A", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"cT", " ", "=", " ", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"RandomReal", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "1"}], ",", "1"}], "}"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "A"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"F", " ", "=", " ", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"RandomReal", "[", 
          RowBox[{"{", 
           RowBox[{"0", ",", 
            RowBox[{"2", "Pi"}]}], "}"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "A"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"pts1", " ", "=", " ", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"R", "[", 
              RowBox[{"[", "i", "]"}], "]"}], 
             RowBox[{"Sqrt", "[", 
              RowBox[{"1", "-", 
               RowBox[{
                RowBox[{"cT", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], "^", "2"}]}], "]"}], 
             RowBox[{"Cos", "[", 
              RowBox[{"F", "[", 
               RowBox[{"[", "i", "]"}], "]"}], "]"}]}], "-", 
            RowBox[{"b", "/", "2"}]}], ",", 
           RowBox[{
            RowBox[{"R", "[", 
             RowBox[{"[", "i", "]"}], "]"}], 
            RowBox[{"Sqrt", "[", 
             RowBox[{"1", "-", 
              RowBox[{
               RowBox[{"cT", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "^", "2"}]}], "]"}], 
            RowBox[{"Sin", "[", 
             RowBox[{"F", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "]"}]}], ",", 
           RowBox[{
            RowBox[{"R", "[", 
             RowBox[{"[", "i", "]"}], "]"}], 
            RowBox[{"cT", "[", 
             RowBox[{"[", "i", "]"}], "]"}]}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "A"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"R", " ", "=", 
       RowBox[{"rejectionSample", "[", "A", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"cT", " ", "=", " ", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"RandomReal", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "1"}], ",", "1"}], "}"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "A"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"F", " ", "=", " ", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"RandomReal", "[", 
          RowBox[{"{", 
           RowBox[{"0", ",", 
            RowBox[{"2", "Pi"}]}], "}"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "A"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"pts2", " ", "=", " ", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"R", "[", 
              RowBox[{"[", "i", "]"}], "]"}], 
             RowBox[{"Sqrt", "[", 
              RowBox[{"1", "-", 
               RowBox[{
                RowBox[{"cT", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], "^", "2"}]}], "]"}], 
             RowBox[{"Cos", "[", 
              RowBox[{"F", "[", 
               RowBox[{"[", "i", "]"}], "]"}], "]"}]}], "+", 
            RowBox[{"b", "/", "2"}]}], ",", 
           RowBox[{
            RowBox[{"R", "[", 
             RowBox[{"[", "i", "]"}], "]"}], 
            RowBox[{"Sqrt", "[", 
             RowBox[{"1", "-", 
              RowBox[{
               RowBox[{"cT", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "^", "2"}]}], "]"}], 
            RowBox[{"Sin", "[", 
             RowBox[{"F", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "]"}]}], ",", 
           RowBox[{
            RowBox[{"R", "[", 
             RowBox[{"[", "i", "]"}], "]"}], 
            RowBox[{"cT", "[", 
             RowBox[{"[", "i", "]"}], "]"}]}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "A"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"colList1", " ", "=", " ", 
       RowBox[{"Table", "[", 
        RowBox[{"0", ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "A"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"colList2", " ", "=", " ", 
       RowBox[{"Table", "[", 
        RowBox[{"0", ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "A"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"For", " ", "[", 
       RowBox[{
        RowBox[{"i", "=", "1"}], ",", 
        RowBox[{"i", "<=", "A"}], ",", 
        RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"For", "[", 
          RowBox[{
           RowBox[{"j", "=", "1"}], ",", 
           RowBox[{"j", "<=", "A"}], ",", 
           RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"distance", "[", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"pts1", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "[", 
                    RowBox[{"[", "1", "]"}], "]"}], ",", 
                   RowBox[{
                    RowBox[{"pts1", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "[", 
                    RowBox[{"[", "2", "]"}], "]"}]}], "}"}], ",", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"pts2", "[", 
                    RowBox[{"[", "j", "]"}], "]"}], "[", 
                    RowBox[{"[", "1", "]"}], "]"}], ",", 
                   RowBox[{
                    RowBox[{"pts2", "[", 
                    RowBox[{"[", "j", "]"}], "]"}], "[", 
                    RowBox[{"[", "2", "]"}], "]"}]}], "}"}]}], "]"}], "<=", 
               "dn"}], ",", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{
                RowBox[{"colList1", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], "+=", " ", "1"}], ";", 
               "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{"colList2", "[", 
                 RowBox[{"[", "j", "]"}], "]"}], "+=", " ", "1"}], ";"}]}], 
             "\[IndentingNewLine]", "]"}], ";"}]}], "\[IndentingNewLine]", 
          "]"}], ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"pts1Col", " ", "=", " ", 
       RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"For", " ", "[", 
       RowBox[{
        RowBox[{"i", "=", "1"}], ",", 
        RowBox[{"i", "\[LessEqual]", "A"}], ",", 
        RowBox[{"i", "++"}], ",", " ", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"colList1", "[", 
             RowBox[{"[", "i", "]"}], "]"}], ">=", "1"}], ",", 
           RowBox[{
            RowBox[{"pts1Col", " ", "=", " ", 
             RowBox[{"Append", "[", 
              RowBox[{"pts1Col", ",", 
               RowBox[{"pts1", "[", 
                RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], ";"}]}], "]"}], 
         ";"}]}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"pts2Col", " ", "=", " ", 
       RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"For", " ", "[", 
       RowBox[{
        RowBox[{"i", "=", "1"}], ",", 
        RowBox[{"i", "\[LessEqual]", "A"}], ",", 
        RowBox[{"i", "++"}], ",", " ", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"colList2", "[", 
             RowBox[{"[", "i", "]"}], "]"}], ">=", "1"}], ",", 
           RowBox[{
            RowBox[{"pts2Col", " ", "=", " ", 
             RowBox[{"Append", "[", 
              RowBox[{"pts2Col", ",", 
               RowBox[{"pts2", "[", 
                RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], ";"}]}], "]"}], 
         ";"}]}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Return", "[", 
       RowBox[{"{", 
        RowBox[{"pts1Col", ",", "pts2Col"}], "}"}], "]"}], ";"}]}], 
    "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Returns", " ", "a", " ", "list", " ", "of", " ", "coordinates", " ", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y", ",", "z"}], "}"}], " ", "of", " ", "wounded", " ",
     "nucleons", " ", "for", " ", "each", " ", "nucleus", " ", 
    RowBox[{"{", " ", 
     RowBox[{
      RowBox[{"{", "coordsA", "}"}], ",", " ", 
      RowBox[{"{", "coordsB", "}"}]}], " ", "}"}]}], " ", "*)"}], 
  "*)"}]], "Input",
 CellChangeTimes->{{3.768232190428417*^9, 3.76823222814485*^9}, 
