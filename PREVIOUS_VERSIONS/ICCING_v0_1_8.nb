Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"PrintTemporary", "[", 
     RowBox[{"Dynamic", "[", 
      RowBox[{"{", 
       RowBox[{"Ethresh", ",", "Eglue", ",", "Etot"}], "}"}], "]"}], "]"}], 
    ";", "\[IndentingNewLine]", 
    RowBox[{"PrintTemporary", "[", 
     RowBox[{"Dynamic", "[", 
      RowBox[{"Style", "[", 
       RowBox[{"mytext", ",", "mycolor"}], "]"}], "]"}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"PrintTemporary", "[", 
     RowBox[{"Dynamic", "[", 
      RowBox[{"\"\<Input Grid \>\"", "<>", 
       RowBox[{"ToString", "[", "len", "]"}], "<>", 
       "\"\< points, Output Grid \>\"", "<>", 
       RowBox[{"ToString", "[", "newlen", "]"}], "<>", "\"\< points\>\""}], 
      "]"}], "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"PrintTemporary", "[", 
     RowBox[{"Dynamic", "[", 
      RowBox[{"\"\<Input Energy \>\"", "<>", 
       RowBox[{"ToString", "[", "Einput", "]"}], "<>", 
       "\"\<, Output Energy \>\"", "<>", 
       RowBox[{"ToString", "[", "Eoutput", "]"}], "<>", "\"\<     \>\"", "<>", 
       RowBox[{"ToString", "[", 
        RowBox[{"Round", "[", 
         FractionBox[
          RowBox[{"100", "*", "Eoutput"}], "Einitial"], "]"}], "]"}], "<>", 
       "\"\<%\>\""}], "]"}], "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"PrintTemporary", "[", 
     RowBox[{"Dynamic", "[", 
      RowBox[{"\"\<Initial Energy \>\"", "<>", 
       RowBox[{"ToString", "[", "Einitial", "]"}], "<>", 
       "\"\<, Current Energy \>\"", "<>", 
       RowBox[{"ToString", "[", 
        RowBox[{"Einput", "+", "Eoutput"}], "]"}]}], "]"}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"PrintTemporary", "[", 
     RowBox[{"Dynamic", "[", "\[IndentingNewLine]", 
      RowBox[{"GraphicsGrid", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"{", "\[IndentingNewLine]", 
          RowBox[{"TRplot", ",", "\[IndentingNewLine]", "newplot"}], 
          "\[IndentingNewLine]", "}"}], "}"}], ",", 
        RowBox[{"ImageSize", "\[Rule]", "1000"}]}], "]"}], 
      "\[IndentingNewLine]", "]"}], "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"PrintTemporary", "[", 
     RowBox[{"Dynamic", "[", "\[IndentingNewLine]", 
      RowBox[{"GraphicsGrid", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"{", "\[IndentingNewLine]", 
          RowBox[{
          "NBplot", ",", "\[IndentingNewLine]", "NSplot", ",", 
           "\[IndentingNewLine]", "NQplot"}], "\[IndentingNewLine]", "}"}], 
         "}"}], ",", 
        RowBox[{"ImageSize", "\[Rule]", "1000"}]}], "]"}], 
      "\[IndentingNewLine]", "]"}], "]"}], ";"}], "*)"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"PrintTemporary", "[", 
     RowBox[{"Dynamic", "[", 
      RowBox[{"\"\<Input Energy \>\"", "<>", 
       RowBox[{"ToString", "[", "Einput", "]"}]}], "]"}], "]"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"PrintTemporary", "[", 
     RowBox[{"Dynamic", "[", 
      RowBox[{"\"\<Output Energy \>\"", "<>", 
       RowBox[{"ToString", "[", "Eoutput", "]"}]}], "]"}], "]"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"PrintTemporary", "[", 
     RowBox[{"Dynamic", "[", 
      RowBox[{
       RowBox[{"ToString", "[", 
        RowBox[{"Round", "[", 
         FractionBox[
          RowBox[{"100", "*", "Eoutput"}], "Einitial"], "]"}], "]"}], "<>", 
       "\"\<%\>\""}], "]"}], "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"While", "[", 
    RowBox[{
     RowBox[{"len", ">", "0"}], ",", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"ran", "=", 
       RowBox[{"RandomInteger", "[", 
        RowBox[{"{", 
         RowBox[{"1", ",", "len"}], "}"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"ranpt", "=", 
       SubscriptBox[
        RowBox[{"ArrayRules", "[", "TR", "]"}], 
        RowBox[{"\[LeftDoubleBracket]", 
         RowBox[{"ran", ",", "1"}], "\[RightDoubleBracket]"}]]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"circlist", "=", 
       RowBox[{"Flatten", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"ranpt", "+", 
            RowBox[{"{", 
             RowBox[{"i", ",", "j"}], "}"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"j", ",", 
             RowBox[{"-", "irad"}], ",", "irad"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", 
             RowBox[{"-", 
              RowBox[{"Round", "[", 
               SqrtBox[
                RowBox[{
                 SuperscriptBox["irad", "2"], "-", 
                 SuperscriptBox["j", "2"]}]], "]"}]}], ",", 
             RowBox[{"Round", "[", 
              SqrtBox[
               RowBox[{
                SuperscriptBox["irad", "2"], "-", 
                SuperscriptBox["j", "2"]}]], "]"}]}], "}"}]}], "]"}], ",", 
         "1"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Etot", "=", 
       RowBox[{
        RowBox[{"Sum", "[", 
         RowBox[{
          SubscriptBox["TR", 
           RowBox[{"\[LeftDoubleBracket]", 
            RowBox[{
             SubscriptBox["circlist", 
              RowBox[{"\[LeftDoubleBracket]", 
               RowBox[{"i", ",", "1"}], "\[RightDoubleBracket]"}]], ",", 
             SubscriptBox["circlist", 
              RowBox[{"\[LeftDoubleBracket]", 
               RowBox[{"i", ",", "2"}], "\[RightDoubleBracket]"}]]}], 
            "\[RightDoubleBracket]"}]], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", 
            RowBox[{"Length", "@", "circlist"}]}], "}"}]}], "]"}], "*", "dx", 
        "*", "dy"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Eglue", "=", 
       RowBox[{"RandomReal", "[", 
        RowBox[{"{", 
         RowBox[{"Ethresh", ",", "1"}], "}"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"myQs", "=", 
       RowBox[{"Mean", "[", 
        RowBox[{"Table", "[", 
         RowBox[{
          SubscriptBox["Qs", 
           RowBox[{"\[LeftDoubleBracket]", 
            RowBox[{
             SubscriptBox["circlist", 
              RowBox[{"\[LeftDoubleBracket]", 
               RowBox[{"i", ",", "1"}], "\[RightDoubleBracket]"}]], ",", 
             SubscriptBox["circlist", 
              RowBox[{"\[LeftDoubleBracket]", 
               RowBox[{"i", ",", "2"}], "\[RightDoubleBracket]"}]]}], 
            "\[RightDoubleBracket]"}]], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", 
            RowBox[{"Length", "@", "circlist"}]}], "}"}]}], "]"}], "]"}]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"result", "=", 
       RowBox[{"SplittingSample", "[", "myQs", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"flav", "=", 
       SubscriptBox["result", 
        RowBox[{"\[LeftDoubleBracket]", 
         RowBox[{"1", ",", "1"}], "\[RightDoubleBracket]"}]]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"\[Alpha]res", "=", 
       SubscriptBox["result", 
        RowBox[{"\[LeftDoubleBracket]", 
         RowBox[{"2", ",", "1"}], "\[RightDoubleBracket]"}]]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"nB", "=", 
       SubscriptBox["result", 
        RowBox[{"\[LeftDoubleBracket]", 
         RowBox[{"1", ",", "3"}], "\[RightDoubleBracket]"}]]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"nS", "=", 
       SubscriptBox["result", 
        RowBox[{"\[LeftDoubleBracket]", 
         RowBox[{"1", ",", "4"}], "\[RightDoubleBracket]"}]]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"nQ", "=", 
       SubscriptBox["result", 
        RowBox[{"\[LeftDoubleBracket]", 
         RowBox[{"1", ",", "5"}], "\[RightDoubleBracket]"}]]}], ";", 
      "\[IndentingNewLine]", 
