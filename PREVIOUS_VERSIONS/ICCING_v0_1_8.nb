95d53f744b65"],

Cell[TextData[{
 StyleBox["\nLet\[CloseCurlyQuote]s fix the problem by doing a better job of \
determining the upper bound used in the Monte Carlo.\n\n\nHow does the \
maximum depend on",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData[
  FormBox["\[Alpha]", TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "0582a4f5-ccc3-489a-9cf9-0c6aad538457"],
 " ?",
 StyleBox["\n",
  FontWeight->"Bold"]
}], "Text",
 CellChangeTimes->{{3.8025284445422187`*^9, 3.8025284847806845`*^9}, {
  3.802528740892324*^9, 3.8025288181933794`*^9}, {3.8025312917084675`*^9, 
  3.802531341944887*^9}},
 FontColor->RGBColor[
  0, 0, 1],ExpressionUUID->"c94a4c94-5a65-4fa3-9c0e-824cd5b47d75"],

Cell[BoxData[
 RowBox[{
  RowBox[{"findmax", "[", 
   RowBox[{"\[Alpha]_", ",", "m_", ",", "Q_"}], "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"r", ",", 
     RowBox[{"corr", "[", 
      RowBox[{"r", ",", "\[Alpha]", ",", "m", ",", "Q"}], "]"}]}], "}"}], "/.", 
   RowBox[{"FindRoot", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"corr", "[", 
         RowBox[{"r", ",", "\[Alpha]", ",", "m", ",", "Q"}], "]"}], ",", 
        "r"}], "]"}], "\[Equal]", "0"}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "0.5"}], "}"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.8025278920162535`*^9, 3.802527935041974*^9}},
 CellLabel->
  "In[1004]:=",ExpressionUUID->"83ed939b-f072-47bf-a64a-f70719f156b1"],

