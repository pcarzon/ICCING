          ",", "\"\<dbar\>\""}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"\[Epsilon]S", "=", 
        RowBox[{"Prepend", "[", 
         RowBox[{
          SubscriptBox[
           RowBox[{"eccDisc", "[", "myS", "]"}], 
           RowBox[{"\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]], 
          ",", "\"\<strange\>\""}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"\[Epsilon]Sbar", "=", 
        RowBox[{"Prepend", "[", 
         RowBox[{
          SubscriptBox[
           RowBox[{"eccDisc", "[", "mySbar", "]"}], 
