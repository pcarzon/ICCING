Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"PrintTemporary", "[", 
      RowBox[{"Dynamic", "[", 
       RowBox[{"{", 
        RowBox[{"Ethresh", ",", "Eglue", ",", "Etot"}], "}"}], "]"}], "]"}], 
     ";"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"PrintTemporary", "[", 
      RowBox[{"Dynamic", "[", 
       RowBox[{"Style", "[", 
        RowBox[{"mytext", ",", "mycolor"}], "]"}], "]"}], "]"}], ";"}], 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"PrintTemporary", "[", 
      RowBox[{"Dynamic", "[", 
       RowBox[{"\"\<Input Grid \>\"", "<>", 
        RowBox[{"ToString", "[", "len", "]"}], "<>", 
        "\"\< points, Output Grid \>\"", "<>", 
        RowBox[{"ToString", "[", "newlen", "]"}], "<>", "\"\< points\>\""}], 
       "]"}], "]"}], ";"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"PrintTemporary", "[", 
      RowBox[{"Dynamic", "[", 
       RowBox[{"\"\<Input Energy \>\"", "<>", 
        RowBox[{"ToString", "[", "Einput", "]"}], "<>", 
        "\"\<, Output Energy \>\"", "<>", 
        RowBox[{"ToString", "[", "Eoutput", "]"}]}], "]"}], "]"}], ";"}], 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"PrintTemporary", "[", 
      RowBox[{"Dynamic", "[", 
       RowBox[{"\"\<Initial Energy \>\"", "<>", 
        RowBox[{"ToString", "[", "Einitial", "]"}], "<>", 
        "\"\<, Current Energy \>\"", "<>", 
        RowBox[{"ToString", "[", 
         RowBox[{"Einput", "+", "Eoutput"}], "]"}]}], "]"}], "]"}], ";"}], 
    "\[IndentingNewLine]", 
    RowBox[{"PrintTemporary", "[", 
     RowBox[{"Dynamic", "[", "\[IndentingNewLine]", 
      RowBox[{"GraphicsGrid", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"{", "\[IndentingNewLine]", 
          RowBox[{"TRplot", ",", "\[IndentingNewLine]", "newplot"}], 
          "\[IndentingNewLine]", "}"}], "}"}], ",", 
        RowBox[{"ImageSize", "\[Rule]", "1000"}]}], "]"}], 
      "\[IndentingNewLine]", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"While", "[", 
    RowBox[{
     RowBox[{"len", ">", "0"}], ",", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
      "Include", " ", "randomly", " ", "fluctuating", " ", "gluon", " ", 
       "energy"}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Eglue", "=", 
       RowBox[{"RandomReal", "[", 
        RowBox[{"{", 
         RowBox[{"Ethresh", ",", "1"}], "}"}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"ran", "=", 
       RowBox[{"RandomInteger", "[", 
        RowBox[{"{", 
         RowBox[{"1", ",", "len"}], "}"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"ranpt", "=", 
       SubscriptBox[
        RowBox[{"ArrayRules", "[", "TR", "]"}], 
        RowBox[{"\[LeftDoubleBracket]", 
         RowBox[{"ran", ",", "1"}], "\[RightDoubleBracket]"}]]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"rad", "=", "0.5"}], ";", "\[IndentingNewLine]", 
      RowBox[{"irad", "=", 
       RowBox[{"Round", "[", 
        FractionBox["rad", "dx"], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"circlist", "=", 
       RowBox[{"Flatten", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"ranpt", "+", 
            RowBox[{"{", 
             RowBox[{"i", ",", "j"}], "}"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"j", ",", 
             RowBox[{"-", "irad"}], ",", "irad"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", 
             RowBox[{"-", 
              RowBox[{"Round", "[", 
               SqrtBox[
                RowBox[{
                 SuperscriptBox["irad", "2"], "-", 
                 SuperscriptBox["j", "2"]}]], "]"}]}], ",", 
             RowBox[{"Round", "[", 
              SqrtBox[
               RowBox[{
                SuperscriptBox["irad", "2"], "-", 
                SuperscriptBox["j", "2"]}]], "]"}]}], "}"}]}], "]"}], ",", 
         "1"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Etot", "=", 
       RowBox[{
        RowBox[{"Sum", "[", 
         RowBox[{
          SubscriptBox["TR", 
           RowBox[{"\[LeftDoubleBracket]", 
            RowBox[{
             SubscriptBox["circlist", 
              RowBox[{"\[LeftDoubleBracket]", 
               RowBox[{"i", ",", "1"}], "\[RightDoubleBracket]"}]], ",", 
             SubscriptBox["circlist", 
              RowBox[{"\[LeftDoubleBracket]", 
               RowBox[{"i", ",", "2"}], "\[RightDoubleBracket]"}]]}], 
            "\[RightDoubleBracket]"}]], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", 
            RowBox[{"Length", "@", "circlist"}]}], "}"}]}], "]"}], "*", "dx", 
        "*", "dy"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"Which", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Etot", "<", "Ethresh"}], ",", "\[IndentingNewLine]", "\t", 
        RowBox[{
         RowBox[{"mycolor", "=", "Red"}], ";", "\t", "\[IndentingNewLine]", 
         "\t", 
         RowBox[{"mytext", "=", "\"\<Below Threshold\>\""}], ";"}], 
        "\[IndentingNewLine]", ",", 
        RowBox[{"Ethresh", "\[LessEqual]", "Etot", "<", "Eglue"}], ",", 
        "\[IndentingNewLine]", "\t", 
        RowBox[{
         RowBox[{"mycolor", "=", "Blue"}], ";", "\[IndentingNewLine]", "\t", 
         RowBox[{"mytext", "=", "\"\<Fails but Retain\>\""}], ";"}], 
        "\[IndentingNewLine]", ",", 
        RowBox[{"Eglue", "\[LessEqual]", "Etot"}], ",", "\[IndentingNewLine]",
         "\t", 
        RowBox[{
         RowBox[{"mycolor", "=", "Green"}], ";", "\[IndentingNewLine]", "\t", 
         RowBox[{"mytext", "=", "\"\<Passes\>\""}], ";"}]}], 
       "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"circpts", "=", 
       RowBox[{"Graphics", "[", 
        RowBox[{"{", 
         RowBox[{"mycolor", ",", "Thick", ",", 
          RowBox[{"Point", "[", "circlist", "]"}]}], "}"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"gluon", "=", 
       RowBox[{"Graphics", "[", 
        RowBox[{"{", 
         RowBox[{"mycolor", ",", "Thick", ",", 
          RowBox[{"Circle", "[", 
           RowBox[{"ranpt", ",", "irad"}], "]"}]}], "}"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"gluonfm", "=", 
       RowBox[{"Graphics", "[", 
        RowBox[{"{", 
         RowBox[{"mycolor", ",", "Thick", ",", 
          RowBox[{"Circle", "[", 
           RowBox[{"ranfmpt", ",", "rad"}], "]"}]}], "}"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"selectplot", "=", 
       RowBox[{"Show", "[", 
        RowBox[{"TRplot", ",", "gluon", ",", "circpts"}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"Which", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Etot", "<", "Ethresh"}], ",", "\[IndentingNewLine]", "\t", 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{
          "If", " ", "the", " ", "contained", " ", "energy", " ", "is", " ", 
           "too", " ", "small", " ", "to", " ", "ever", " ", "pair", " ", 
           "produce"}], ",", " ", 
          RowBox[{
          "just", " ", "transfer", " ", "it", " ", "over", " ", "to", " ", 
           "the", " ", "output", " ", "grid"}]}], " ", "*)"}], 
        "\[IndentingNewLine]", "\t", 
        RowBox[{
         RowBox[{"For", "[", 
          RowBox[{
           RowBox[{"i", "=", "1"}], ",", 
           RowBox[{"i", "\[LessEqual]", 
            RowBox[{"Length", "[", "circlist", "]"}]}], ",", 
           RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", "\t", 
           RowBox[{
            RowBox[{
             SubscriptBox["newTRgrid", 
              RowBox[{"\[LeftDoubleBracket]", 
               RowBox[{
                SubscriptBox["circlist", 
                 RowBox[{"\[LeftDoubleBracket]", 
                  RowBox[{"i", ",", "1"}], "\[RightDoubleBracket]"}]], ",", 
                SubscriptBox["circlist", 
                 RowBox[{"\[LeftDoubleBracket]", 
                  RowBox[{"i", ",", "2"}], "\[RightDoubleBracket]"}]]}], 
               "\[RightDoubleBracket]"}]], "+=", 
             SubscriptBox["TR", 
              RowBox[{"\[LeftDoubleBracket]", 
               RowBox[{
                SubscriptBox["circlist", 
                 RowBox[{"\[LeftDoubleBracket]", 
                  RowBox[{"i", ",", "1"}], "\[RightDoubleBracket]"}]], ",", 
                SubscriptBox["circlist", 
                 RowBox[{"\[LeftDoubleBracket]", 
                  RowBox[{"i", ",", "2"}], "\[RightDoubleBracket]"}]]}], 
               "\[RightDoubleBracket]"}]]}], ";", "\[IndentingNewLine]", "\t", 
            RowBox[{
             SubscriptBox["TR", 
              RowBox[{"\[LeftDoubleBracket]", 
               RowBox[{
                SubscriptBox["circlist", 
                 RowBox[{"\[LeftDoubleBracket]", 
                  RowBox[{"i", ",", "1"}], "\[RightDoubleBracket]"}]], ",", 
                SubscriptBox["circlist", 
                 RowBox[{"\[LeftDoubleBracket]", 
                  RowBox[{"i", ",", "2"}], "\[RightDoubleBracket]"}]]}], 
               "\[RightDoubleBracket]"}]], "=", "0"}], ";"}]}], 
          "\[IndentingNewLine]", "\t", "]"}], ";", "\[IndentingNewLine]", 
         "\t", 
         RowBox[{"TRplot", "=", 
          RowBox[{"ArrayPlot", "[", 
           RowBox[{
            RowBox[{"Transpose", "@", "TR"}], ",", 
            RowBox[{"PlotLabel", "\[Rule]", "\"\<Old\>\""}], ",", 
            RowBox[{"ColorFunction", "\[Rule]", "\"\<SunsetColors\>\""}]}], 
           "]"}]}], ";", "\[IndentingNewLine]", "\t", 
         RowBox[{"newplot", "=", 
          RowBox[{"ArrayPlot", "[", 
           RowBox[{
            RowBox[{"Transpose", "@", "newTRgrid"}], ",", 
            RowBox[{"PlotLabel", "\[Rule]", "\"\<New\>\""}], ",", 
            RowBox[{"ColorFunction", "\[Rule]", "\"\<SunsetColors\>\""}]}], 
           "]"}]}], ";", "\[IndentingNewLine]", "\t", 
         RowBox[{"Einput", "=", 
          RowBox[{
           RowBox[{"Sum", "[", 
            RowBox[{
             SubscriptBox["TR", 
              RowBox[{"\[LeftDoubleBracket]", 
               RowBox[{"i", ",", "j"}], "\[RightDoubleBracket]"}]], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "1", ",", "imax"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"j", ",", "1", ",", "jmax"}], "}"}]}], "]"}], "*", "dx",
            "*", "dy"}]}], ";", "\[IndentingNewLine]", "\t", 
         RowBox[{"Eoutput", "=", 
          RowBox[{
           RowBox[{"Sum", "[", 
            RowBox[{
             SubscriptBox["newTRgrid", 
              RowBox[{"\[LeftDoubleBracket]", 
               RowBox[{"i", ",", "j"}], "\[RightDoubleBracket]"}]], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "1", ",", "imax"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"j", ",", "1", ",", "jmax"}], "}"}]}], "]"}], "*", "dx",
            "*", "dy"}]}], ";"}], "\[IndentingNewLine]", "\t", 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{"AppendTo", "[", 
           RowBox[{"mymovie", ",", 
            RowBox[{"GraphicsGrid", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"{", 
                RowBox[{"TRplot", ",", "newplot"}], "}"}], "}"}], ",", 
              RowBox[{"ImageSize", "\[Rule]", "1000"}]}], "]"}]}], "]"}], 
          ";"}], "*)"}], "\[IndentingNewLine]", ",", 
        RowBox[{"Ethresh", "\[LessEqual]", "Etot", "<", "Eglue"}], ",", 
        "\[IndentingNewLine]", "\t", 
        RowBox[{"(*", " ", 
         RowBox[{
         "If", " ", "the", " ", "contained", " ", "energy", " ", "is", " ", 
          "too", " ", "small", " ", "to", " ", "make", " ", "this", " ", 
          RowBox[{"gluon", " ", "--"}], " ", "but", " ", "could", " ", "down",
           " ", "the", " ", 
          RowBox[{"line", " ", "--"}], " ", "then", " ", "skip", " ", "it"}], 
         " ", "*)"}], "\[IndentingNewLine]", "\t", "\"\<\>\"", 
        "\[IndentingNewLine]", ",", 
        RowBox[{"Eglue", "\[LessEqual]", "Etot"}], ",", "\[IndentingNewLine]",
         "\t", 
        RowBox[{"(*", " ", 
         RowBox[{
         "If", " ", "the", " ", "contained", " ", "energy", " ", "is", " ", 
          "sufficient", " ", "to", " ", "make", " ", "this", " ", "gluon", 
          " ", "then", " ", "subtract", " ", "it", " ", "proportionally", " ",
           "from", " ", "each", " ", "cell"}], " ", "*)"}], 
        "\[IndentingNewLine]", "\t", 
        RowBox[{
         RowBox[{"For", "[", 
          RowBox[{
           RowBox[{"i", "=", "1"}], ",", 
           RowBox[{"i", "\[LessEqual]", 
            RowBox[{"Length", "[", "circlist", "]"}]}], ",", 
           RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", "\t", 
           RowBox[{
            RowBox[{"\[CapitalDelta]E", "=", 
             RowBox[{
              FractionBox["Eglue", "Etot"], 
              SubscriptBox["TR", 
               RowBox[{"\[LeftDoubleBracket]", 
                RowBox[{
                 SubscriptBox["circlist", 
                  RowBox[{"\[LeftDoubleBracket]", 
                   RowBox[{"i", ",", "1"}], "\[RightDoubleBracket]"}]], ",", 
                 SubscriptBox["circlist", 
                  RowBox[{"\[LeftDoubleBracket]", 
                   RowBox[{"i", ",", "2"}], "\[RightDoubleBracket]"}]]}], 
                "\[RightDoubleBracket]"}]]}]}], ";", "\[IndentingNewLine]", 
            "\t", 
            RowBox[{
             SubscriptBox["newTRgrid", 
              RowBox[{"\[LeftDoubleBracket]", 
               RowBox[{
                SubscriptBox["circlist", 
                 RowBox[{"\[LeftDoubleBracket]", 
                  RowBox[{"i", ",", "1"}], "\[RightDoubleBracket]"}]], ",", 
                SubscriptBox["circlist", 
                 RowBox[{"\[LeftDoubleBracket]", 
                  RowBox[{"i", ",", "2"}], "\[RightDoubleBracket]"}]]}], 
               "\[RightDoubleBracket]"}]], "+=", "\[CapitalDelta]E"}], ";", 
            "\[IndentingNewLine]", "\t", 
            RowBox[{
             SubscriptBox["TR", 
              RowBox[{"\[LeftDoubleBracket]", 
               RowBox[{
                SubscriptBox["circlist", 
                 RowBox[{"\[LeftDoubleBracket]", 
                  RowBox[{"i", ",", "1"}], "\[RightDoubleBracket]"}]], ",", 
                SubscriptBox["circlist", 
                 RowBox[{"\[LeftDoubleBracket]", 
                  RowBox[{"i", ",", "2"}], "\[RightDoubleBracket]"}]]}], 
               "\[RightDoubleBracket]"}]], "-=", "\[CapitalDelta]E"}], 
            ";"}]}], "\[IndentingNewLine]", "\t", "]"}], ";", 
         "\[IndentingNewLine]", "\t", 
         RowBox[{"TRplot", "=", 
          RowBox[{"ArrayPlot", "[", 
           RowBox[{
            RowBox[{"Transpose", "@", "TR"}], ",", 
            RowBox[{"PlotLabel", "\[Rule]", "\"\<Old\>\""}], ",", 
            RowBox[{"ColorFunction", "\[Rule]", "\"\<SunsetColors\>\""}]}], 
           "]"}]}], ";", "\[IndentingNewLine]", "\t", 
         RowBox[{"newplot", "=", 
          RowBox[{"ArrayPlot", "[", 
           RowBox[{
            RowBox[{"Transpose", "@", "newTRgrid"}], ",", 
            RowBox[{"PlotLabel", "\[Rule]", "\"\<New\>\""}], ",", 
