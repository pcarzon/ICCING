Cell[BoxData[
 RowBox[{"(*", "  ", 
  RowBox[{
   RowBox[{"Old", " ", "splitting", " ", 
    RowBox[{"MC", ".", "  ", "This"}], " ", "one", " ", "is", " ", "not", " ",
     "done", " ", "correctly", " ", "since", " ", "the", " ", "MC", " ", 
    "ceiling", " ", 
    RowBox[{"(", 
     RowBox[{
     "the", " ", "formula", " ", "coded", " ", "explicitly", " ", "here"}], 
     ")"}], " ", "is", " ", 
    RowBox[{"wrong", ".", "  ", "It"}], " ", "has", " ", "been", " ", 
    "superseded", " ", "by", " ", "the", " ", "new", " ", "definition", " ", 
    RowBox[{"below", ".", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
      "Define", " ", "the", " ", "procedure", " ", "to", " ", "sample", " ", 
       "the", " ", "redistribution", " ", "of", " ", "a", " ", "possible", 
       " ", "gluon", " ", "splitting"}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"SplittingSample", "[", "Qs_", "]"}]}]}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"charges", ",", "m", ",", "IsQuark", ",", 
       RowBox[{"o", "=", 
        RowBox[{"{", "}"}]}], ",", "r", ",", "y", ",", "\[Alpha]temp", ",", 
       RowBox[{"rfinal", "=", "\"\<\>\""}], ",", 
       RowBox[{"\[Phi]", "=", 
        RowBox[{"RandomReal", "[", 
         RowBox[{"{", 
          RowBox[{"0", ",", 
           RowBox[{"2", "\[Pi]"}]}], "}"}], "]"}]}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"charges", "=", 
       RowBox[{"RollFlavor", "[", "Qs", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"m", "=", 
       SubscriptBox["charges", 
        RowBox[{"\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"\[Alpha]temp", "=", 
       RowBox[{"RandomReal", "[", 
        RowBox[{"{", 
         RowBox[{"\[Alpha]min", ",", 
          RowBox[{"1", "-", "\[Alpha]min"}]}], "}"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"IsQuark", "=", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          SubscriptBox["charges", 
           RowBox[{"\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]], 
          "\[NotEqual]", "\"\<g\>\""}], ",", "True", ",", "False"}], "]"}]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{"IsQuark", ",", "\[IndentingNewLine]", 
        RowBox[{"While", "[", 
         RowBox[{
          RowBox[{"rfinal", "\[Equal]", "\"\<\>\""}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"r", " ", "=", " ", 
            RowBox[{"RandomReal", "[", 
             RowBox[{"{", 
              RowBox[{"0", ",", "rmax"}], "}"}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"y", " ", "=", " ", 
            RowBox[{"RandomReal", "[", "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"y", "<", 
              RowBox[{
               RowBox[{"corr", "[", 
                RowBox[{"r", ",", "\[Alpha]temp", ",", "m", ",", "Qs"}], 
                "]"}], "/", 
               RowBox[{"(", 
                RowBox[{"1.2", "*", 
                 FractionBox[
                  RowBox[{
                   SuperscriptBox["Qs", "2"], " ", 
                   SuperscriptBox[
                    RowBox[{"(", 
                    RowBox[{"1", "-", 
                    RowBox[{"2", " ", "\[Alpha]temp"}], "+", 
                    RowBox[{"2", " ", 
                    SuperscriptBox["\[Alpha]temp", "2"]}]}], ")"}], "2"]}], 
                  RowBox[{"32", " ", 
                   SuperscriptBox["\[Pi]", "2"]}]]}], ")"}]}]}], ",", 
             RowBox[{"rfinal", "=", "r"}]}], "]"}], ";"}]}], 
