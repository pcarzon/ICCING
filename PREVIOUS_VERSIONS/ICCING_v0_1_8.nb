        "Prints", " ", "an", " ", "updating", " ", "progress", " ", "report", 
         " ", "on", " ", "the", " ", "algorithm"}], ",", " ", 
        RowBox[{
        "reporting", " ", "the", " ", "percentage", " ", "of", " ", "energy", 
         " ", "redistributed"}]}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"PrintTemporary", "[", 
       RowBox[{"Dynamic", "[", 
        RowBox[{
         RowBox[{"ToString", "[", 
          RowBox[{"Round", "[", 
           FractionBox[
            RowBox[{"100", "*", "Eoutput"}], "Einitial"], "]"}], "]"}], "<>", 
         "\"\<% Complete\>\""}], "]"}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{"DebugFlag", ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"PrintTemporary", "[", "\"\<\>\"", "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"PrintTemporary", "[", 
          RowBox[{"Dynamic", "[", 
           RowBox[{"\"\<Input Energy \>\"", "<>", 
            RowBox[{"ToString", "[", 
             RowBox[{"InputForm", "@", "Einput"}], "]"}], "<>", 
            "\"\< GeV per unit rapidity\>\""}], "]"}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"PrintTemporary", "[", 
          RowBox[{"Dynamic", "[", 
           RowBox[{"\"\<Output Energy \>\"", "<>", 
            RowBox[{"ToString", "[", 
             RowBox[{"InputForm", "@", "Eoutput"}], "]"}], "<>", 
            "\"\< GeV per unit rapidity\>\""}], "]"}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"PrintTemporary", "[", 
          RowBox[{"Dynamic", "[", 
           RowBox[{"\"\<len =\>\"", "<>", 
            RowBox[{"ToString", "[", "len", "]"}]}], "]"}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"PrintTemporary", "[", 
          RowBox[{"Dynamic", "[", 
           RowBox[{"\"\<Gluon Position = {\>\"", "<>", 
            RowBox[{"ToString", "[", 
             RowBox[{"xmin", "+", 
              RowBox[{
               SubscriptBox["ranpt", 
                RowBox[{
                "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]], 
               "dx"}]}], "]"}], "<>", "\"\< fm, \>\"", "<>", 
            RowBox[{"ToString", "[", 
             RowBox[{"ymin", "+", 
              RowBox[{
               SubscriptBox["ranpt", 
                RowBox[{
                "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]], 
               "dy"}]}], "]"}], "<>", "\"\< fm}\>\""}], "]"}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"PrintTemporary", "[", 
          RowBox[{"Dynamic", "[", 
           RowBox[{"\"\<Gluon Energy: \>\"", "<>", 
            RowBox[{"ToString", "[", "Eglue", "]"}], "<>", "\"\< GeV\>\""}], 
           "]"}], "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"PrintTemporary", "[", 
          RowBox[{"Dynamic", "[", 
           RowBox[{
