   RowBox[{
    RowBox[{
    "When", " ", "called", " ", "with", " ", "two", " ", "arguments"}], ",", 
    " ", 
    RowBox[{
    "the", " ", "same", " ", "routine", " ", "runs", " ", "in", " ", "a", " ",
      "loop", " ", "to", " ", "examine", " ", "a", " ", "range", " ", "of", 
     " ", "event", " ", "numbers", " ", "from", " ", "the", " ", "first", " ",
      "one", " ", "to", " ", "the", " ", "second", " ", 
     RowBox[{"one", "."}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ViewTrento", "[", 
    RowBox[{"num1_", ",", "num2_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "i", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "num1"}], ",", 
       RowBox[{"i", "\[LessEqual]", "num2"}], ",", 
       RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"ViewTrento", "[", "i", "]"}], ";"}]}], "\[IndentingNewLine]",
       "]"}]}], "\[IndentingNewLine]", "]"}]}]}]], "Input",
