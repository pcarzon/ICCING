                   RowBox[{
                   "\[LeftDoubleBracket]", "5", "\[RightDoubleBracket]"}]]}], 
                 SubscriptBox["mydata", 
                  RowBox[{
                  "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]]], 
                "]"}], ",", 
               RowBox[{"Round", "[", 
                FractionBox[
                 RowBox[{
                  SubscriptBox["#", 
                   RowBox[{
                   "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]], 
                  "-", 
                  SubscriptBox["mydata", 
                   RowBox[{
                   "\[LeftDoubleBracket]", "6", "\[RightDoubleBracket]"}]]}], 
                 SubscriptBox["mydata", 
                  RowBox[{
                  "\[LeftDoubleBracket]", "3", "\[RightDoubleBracket]"}]]], 
                "]"}]}], "}"}], "\[Rule]", 
             SubscriptBox["#", 
              RowBox[{
              "\[LeftDoubleBracket]", "3", "\[RightDoubleBracket]"}]]}], 
            "&"}], ",", "myTA"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"imax", ",", "jmax"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"mysparseTB", "=", 
       RowBox[{"SparseArray", "[", 
        RowBox[{
         RowBox[{"Map", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"Round", "[", 
                FractionBox[
                 RowBox[{
                  SubscriptBox["#", 
                   RowBox[{
                   "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]], 
                  "-", 
                  SubscriptBox["mydata", 
                   RowBox[{
                   "\[LeftDoubleBracket]", "5", "\[RightDoubleBracket]"}]]}], 
                 SubscriptBox["mydata", 
                  RowBox[{
                  "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]]], 
                "]"}], ",", 
               RowBox[{"Round", "[", 
                FractionBox[
                 RowBox[{
                  SubscriptBox["#", 
                   RowBox[{
                   "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]], 
                  "-", 
                  SubscriptBox["mydata", 
                   RowBox[{
                   "\[LeftDoubleBracket]", "6", "\[RightDoubleBracket]"}]]}], 
                 SubscriptBox["mydata", 
                  RowBox[{
                  "\[LeftDoubleBracket]", "3", "\[RightDoubleBracket]"}]]], 
                "]"}]}], "}"}], "\[Rule]", 
             SubscriptBox["#", 
              RowBox[{
              "\[LeftDoubleBracket]", "3", "\[RightDoubleBracket]"}]]}], 
            "&"}], ",", "myTB"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"imax", ",", "jmax"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"mysparseTR", "=", 
       RowBox[{"SparseArray", "[", 
        RowBox[{
         RowBox[{"Map", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"Round", "[", 
                FractionBox[
                 RowBox[{
                  SubscriptBox["#", 
                   RowBox[{
                   "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]], 
                  "-", 
                  SubscriptBox["mydata", 
                   RowBox[{
                   "\[LeftDoubleBracket]", "5", "\[RightDoubleBracket]"}]]}], 
                 SubscriptBox["mydata", 
                  RowBox[{
                  "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]]], 
                "]"}], ",", 
               RowBox[{"Round", "[", 
                FractionBox[
                 RowBox[{
                  SubscriptBox["#", 
                   RowBox[{
                   "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]], 
                  "-", 
                  SubscriptBox["mydata", 
                   RowBox[{
                   "\[LeftDoubleBracket]", "6", "\[RightDoubleBracket]"}]]}], 
                 SubscriptBox["mydata", 
                  RowBox[{
                  "\[LeftDoubleBracket]", "3", "\[RightDoubleBracket]"}]]], 
                "]"}]}], "}"}], "\[Rule]", 
             SubscriptBox["#", 
