      RowBox[{"{", 
       RowBox[{
       "num1", ",", "den1", ",", "E1", ",", "num2", ",", "den2", ",", "E2", 
        ",", "num3", ",", "den3", ",", "E3", ",", "tot", ",", "icom", ",", 
        "jcom"}], "}"}], ",", "\[IndentingNewLine]", 
