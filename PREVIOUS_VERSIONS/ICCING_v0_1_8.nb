Cell[TextData[{
 StyleBox["\nWith increasing ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   SubscriptBox["Q", "s"], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"6e79924f-c229-4286-b9fc-aaa41b15c9bd"],
 StyleBox[" the peak moves backward (to smaller values of r) and the height \
of the peak grows almost linearly with ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox["Q", TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"10a69b25-a04b-4502-8eee-f5f3faaecf27"],
 StyleBox["s\n\nFor small ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   SubscriptBox["Q", "s"], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"f92d01f2-1e53-4faf-a4d3-5c1f701755bf"],
 StyleBox[" the peak moves outward (to larger r) and the height of the peak \
shrinks linearly with Qs.\n\nWhen position of the maximum is larger than the \
nonperturbative cutoff (default: 0.5 fm) the maximum is just given by the \
value at the cutoff.",
  FontWeight->"Bold"],
 "\n\n\n",
 StyleBox["Next let\[CloseCurlyQuote]s use the ceiling at ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Alpha]", "=", "0"}], TraditionalForm]],
  FormatType->"TraditionalForm",
  FontWeight->"Bold",ExpressionUUID->"5b3b9cd1-e98f-45ff-949b-1d2c16f8fdf8"],
 StyleBox[" and test that, for random parameters (m, Qs), the ceiling is \
always above the curve:",
  FontWeight->"Bold"]
}], "Text",
 CellChangeTimes->{{3.8025284445422187`*^9, 3.8025284847806845`*^9}, {
  3.802528740892324*^9, 3.8025288181933794`*^9}, {3.802531347257676*^9, 
  3.802531356492985*^9}, {3.8025314293852205`*^9, 3.8025315756725245`*^9}, {
  3.8025333542941704`*^9, 3.802533470249789*^9}, {3.8025418295153327`*^9, 
  3.802541888846794*^9}, {3.8025419711319575`*^9, 3.8025419915673656`*^9}, {
  3.8025420272825823`*^9, 3.8025421047223063`*^9}, {3.8025421522857313`*^9, 
  3.802542172813589*^9}, {3.8026126737357388`*^9, 3.8026126784381375`*^9}, {
  3.8026127662616854`*^9, 3.802612767217175*^9}},
 FontColor->RGBColor[
  0, 0, 1],ExpressionUUID->"d64a1c4c-50c6-4429-a871-9df4bb57cf9c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"TestMC", "[", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"mymass", ",", "myQsat", ",", "mymax"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"mymass", "=", 
      RowBox[{"RandomChoice", "[", 
       RowBox[{"{", 
        RowBox[{"0.0023", ",", "0.0048", ",", "0.095", ",", "1.29"}], "}"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<m = \>\"", ",", "mymass"}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"myQsat", "=", 
      RowBox[{"RandomReal", "[", 
       RowBox[{"{", 
        RowBox[{"0.01", ",", "3"}], "}"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<Qs = \>\"", ",", "myQsat"}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"mymax", "=", 
      RowBox[{"1.01", "*", 
       SubscriptBox[
        RowBox[{"FindMaximum", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"corr", "[", 
             RowBox[{"r", ",", "0", ",", "mymass", ",", "myQsat"}], "]"}], 
            ",", 
            RowBox[{"0", "<", "r", "<", "rmax"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"r", ",", "0.2"}], "}"}]}], "]"}], 
        RowBox[{"\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]]}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<Ceiling = \>\"", ",", "mymax"}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Plot3D", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"corr", "[", 
          RowBox[{"r", ",", "\[Alpha]", ",", "mymass", ",", "myQsat"}], "]"}],
          ",", "mymax"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"r", ",", "0", ",", 
         RowBox[{"rmax", "*", "1.01"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Alpha]", ",", "0", ",", "1"}], "}"}], ",", 
       RowBox[{"ImageSize", "\[Rule]", "500"}]}], "]"}]}]}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Check", "[", 
      RowBox[{
       RowBox[{"Print", "[", 
        RowBox[{"Plot3D", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"corr", "[", 
             RowBox[{"r", ",", "\[Alpha]", ",", "mymass", ",", "myQsat"}], 
             "]"}], ",", "mymax"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"r", ",", "0", ",", "3"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"\[Alpha]", ",", "0", ",", "1"}], "}"}], ",", 
          RowBox[{"ImageSize", "\[Rule]", "500"}]}], "]"}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Print", "[", "\"\<Failure\>\"", "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Return", "[", "1", "]"}], ";"}]}], "\[IndentingNewLine]", 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Return", "[", "0", "]"}], ";"}], "*)"}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.8025291445555925`*^9, 3.8025292067573357`*^9}, {
   3.8025292435084286`*^9, 3.8025293781318455`*^9}, {3.8025294957543693`*^9, 
