                    RowBox[{
                    "\[LeftDoubleBracket]", "k", "\[RightDoubleBracket]"}]], 
                    "-", "qbarpt"}], ")"}], ".", 
                    RowBox[{"(", 
                    RowBox[{
                    SubscriptBox["qbarcirclist", 
                    RowBox[{
                    "\[LeftDoubleBracket]", "k", "\[RightDoubleBracket]"}]], 
                    "-", "qbarpt"}], ")"}]}], 
                    RowBox[{"2", " ", 
                    SuperscriptBox["qirad", "2"]}]]}], "]"}]}]}], ";"}]}], 
                   "\[IndentingNewLine]", "\t\t\t", "]"}]}]}], 
                "\[IndentingNewLine]", "\t\t", "]"}], ";"}], 
              "\[IndentingNewLine]", "\t", ",", "\[IndentingNewLine]", "\t\t", 
              RowBox[{
               RowBox[{"mytext", "=", "\"\<Remains a gluon; copying\>\""}], 
               ";", "\[IndentingNewLine]", "\t\t", 
               RowBox[{"(*", " ", 
                RowBox[{
                 RowBox[{
                 "If", " ", "the", " ", "outcome", " ", "remains", " ", "a", 
                  " ", "gluon"}], ",", " ", 
