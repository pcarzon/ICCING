          RowBox[{"{", 
           RowBox[{"j", ",", "1", ",", "jmax"}], "}"}]}], "]"}], "*", 
        SubscriptBox["mydata", 
         RowBox[{"\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]], "*", 
        SubscriptBox["mydata", 
         RowBox[{"\[LeftDoubleBracket]", "3", "\[RightDoubleBracket]"}]], "*",
         "\[Tau]0"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"mytitle", "=", 
       RowBox[{"\"\<Event #\>\"", "<>", 
        RowBox[{"ToString", "[", "num", "]"}], "<>", "\"\<: \>\"", "<>", 
        RowBox[{"ToString", "[", "myEtot", "]"}], "<>", 
        "\"\< GeV per unit rapidity\>\""}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"myplot", "=", 
