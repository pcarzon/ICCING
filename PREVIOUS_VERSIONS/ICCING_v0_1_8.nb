Cell[TextData[{
 StyleBox["\nSuccess!  The input distribution is successfully reproduced by \
the MC sampling.\n\nThis works for multiple choices of parameters (m, Qs), \
and it correctly captures the case when the peak is out beyond the cutoff \
rmax.\n\n\n\nThen the corrected version of the splitting routine has two \
changes:\n\n\tRandom alpha sample is moved inside the MC \
\[OpenCurlyDoubleQuote]while\[CloseCurlyDoubleQuote] loop\n\t\n\tNew MC \
ceiling obtained by finding the maximum at ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Alpha]", "=", "0"}], TraditionalForm]],
  FormatType->"TraditionalForm",
  FontWeight->"Bold",ExpressionUUID->"b56e4791-7d71-4e32-9aba-4cdceeca5d96"],
 StyleBox[".\n\t",
  FontWeight->"Bold"]
}], "Text",
 CellChangeTimes->{{3.8025284445422187`*^9, 3.8025284847806845`*^9}, {
   3.802528740892324*^9, 3.8025288181933794`*^9}, {3.802531347257676*^9, 
   3.802531356492985*^9}, {3.8025314293852205`*^9, 3.8025315756725245`*^9}, {
   3.802531641660137*^9, 3.802531674155819*^9}, {3.80253172953129*^9, 
   3.8025317641725845`*^9}, {3.8025319683008127`*^9, 3.802531994169647*^9}, {
   3.802536001638242*^9, 3.802536029139614*^9}, {3.8025415639960003`*^9, 
   3.8025415678507166`*^9}, {3.8025428092145557`*^9, 
   3.8025428245889854`*^9}, {3.8025429922177367`*^9, 
   3.8025430582497516`*^9}, {3.8025431406533957`*^9, 3.802543152028289*^9}, {
   3.802543217002043*^9, 3.802543217161584*^9}, {3.8025441628561907`*^9, 
   3.8025441947138762`*^9}, {3.8025453543138103`*^9, 
   3.8025453910983405`*^9}, {3.8026010032570033`*^9, 3.80260103093853*^9}, {
   3.8026129616514072`*^9, 3.802613140531852*^9}, 3.8026138186285563`*^9},
 FontColor->RGBColor[
  0, 0, 1],ExpressionUUID->"d9b9dd85-54c2-45ef-be2f-794d0375f1d2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Define", " ", "the", " ", "procedure", " ", "to", " ", "sample", " ", 
    "the", " ", "redistribution", " ", "of", " ", "a", " ", "possible", " ", 
    "gluon", " ", "splitting"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"SplittingSample2", "[", "Qs_", "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"MCceiling", ",", "charges", ",", "m", ",", "IsQuark", ",", 
       RowBox[{"o", "=", 
        RowBox[{"{", "}"}]}], ",", "r", ",", "y", ",", "\[Alpha]temp", ",", 
       RowBox[{"rfinal", "=", "\"\<\>\""}], ",", 
       RowBox[{"\[Phi]", "=", 
        RowBox[{"RandomReal", "[", 
         RowBox[{"{", 
          RowBox[{"0", ",", 
           RowBox[{"2", "\[Pi]"}]}], "}"}], "]"}]}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"charges", "=", 
       RowBox[{"RollFlavor", "[", "Qs", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"m", "=", 
       SubscriptBox["charges", 
        RowBox[{"\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"IsQuark", "=", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          SubscriptBox["charges", 
           RowBox[{"\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]], 
          "\[NotEqual]", "\"\<g\>\""}], ",", "True", ",", "False"}], "]"}]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{"IsQuark", ",", "\[IndentingNewLine]", 
        RowBox[{"While", "[", 
         RowBox[{
          RowBox[{"rfinal", "\[Equal]", "\"\<\>\""}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"r", " ", "=", " ", 
            RowBox[{"RandomReal", "[", 
             RowBox[{"{", 
              RowBox[{"0", ",", "rmax"}], "}"}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"\[Alpha]temp", "=", 
            RowBox[{"RandomReal", "[", 
             RowBox[{"{", 
              RowBox[{"\[Alpha]min", ",", 
               RowBox[{"1", "-", "\[Alpha]min"}]}], "}"}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"MCceiling", "=", 
            RowBox[{"1.01", "*", 
             SubscriptBox[
              RowBox[{"FindMaximum", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"corr", "[", 
                   RowBox[{"r", ",", "0", ",", "m", ",", "Qs"}], "]"}], ",", 
                  RowBox[{"0", "<", "r", "<", "rmax"}]}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{"r", ",", "0.2"}], "}"}]}], "]"}], 
              RowBox[{
              "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]]}]}], 
           ";", "\[IndentingNewLine]", 
           RowBox[{"y", " ", "=", " ", 
            RowBox[{"RandomReal", "[", 
             RowBox[{"{", 
              RowBox[{"0", ",", "MCceiling"}], "}"}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"y", "<", 
              RowBox[{"corr", "[", 
               RowBox[{"r", ",", "\[Alpha]temp", ",", "m", ",", "Qs"}], 
               "]"}]}], ",", 
             RowBox[{"rfinal", "=", "r"}]}], "]"}], ";"}]}], 
         "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Return", "[", 
          RowBox[{"{", 
           RowBox[{"charges", ",", 
            RowBox[{"{", 
             RowBox[{"1", ",", "0", ",", "0"}], "}"}]}], "}"}], "]"}], 
         ";"}]}], "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Return", "[", 
       RowBox[{"{", 
        RowBox[{"charges", ",", 
         RowBox[{"{", 
          RowBox[{"\[Alpha]temp", ",", 
           RowBox[{"rfinal", " ", 
            RowBox[{"Cos", "[", "\[Phi]", "]"}]}], ",", 
           RowBox[{"rfinal", " ", 
            RowBox[{"Sin", "[", "\[Phi]", "]"}]}]}], "}"}]}], "}"}], 
       "]"}]}]}], "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{
      RowBox[{
      "Returns", " ", "the", " ", "charges", " ", "of", " ", "the", " ", 
       "selected", " ", "flavor"}], ",", " ", 
      RowBox[{
      "the", " ", "fraction", " ", "of", " ", "energy", " ", "being", " ", 
       "redistributed"}], ",", " ", 
      RowBox[{"and", " ", "the", " ", 
       RowBox[{"displacement", ":", "  ", 
        RowBox[{"{", " ", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"f", ",", "m", ",", "b", ",", "s", ",", "q"}], "}"}], " ", 
          ",", " ", 
          RowBox[{"{", 
           RowBox[{
           "\[Alpha]", ",", "\[CapitalDelta]x", ",", "\[CapitalDelta]y"}], 
           "}"}]}], " ", "}"}]}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
    "]"}], "  "}]}]], "Input",
 CellChangeTimes->{{3.768234724840887*^9, 3.768234755052925*^9}, {
   3.7682348838536887`*^9, 3.7682349244327316`*^9}, {3.768235011565856*^9, 
   3.7682350200774107`*^9}, 3.768304782220622*^9, 3.768304839145446*^9, {
   3.8025445798656044`*^9, 3.802544759027027*^9}, {3.8025447955724063`*^9, 
   3.8025449687734528`*^9}, {3.8025450078456182`*^9, 
   3.8025450139765573`*^9}, {3.802606833544387*^9, 
   3.802606869393509*^9}},ExpressionUUID->"4c0d1ba1-218e-45d0-9aba-\
13052c07d128"],

