\>", "Item",
 CellChangeTimes->{{3.767963131741216*^9, 3.7679631524919357`*^9}, {
  3.7679631982353563`*^9, 3.7679631982353563`*^9}, {3.768065882635975*^9, 
  3.7680659145467463`*^9}},ExpressionUUID->"e20d2919-7d61-4956-96f9-\
3f920abc1f00"],

Cell[TextData[{
 "Should probably calculate / include the g --> gg splitting probability and \
include it at the same order, since we\[CloseCurlyQuote]re not just \
generating a new charge distribution, but also redistributing energy.  So \
there should also be a valid ",
 Cell[BoxData[
  FormBox[
   RowBox[{"O", "(", 
    SubscriptBox["\[Alpha]", "s"], ")"}], TraditionalForm]],ExpressionUUID->
  "717a8e74-4fa3-45b9-8f28-b722e353cd0c"],
 " process that redistributes the energy but creates no charge"
}], "Item",
 CellChangeTimes->{{3.767963131741216*^9, 3.7679631524919357`*^9}, {
  3.7679632032767973`*^9, 3.767963237008069*^9}, {3.7679632676201043`*^9, 
  3.767963319372579*^9}, {3.7679634337997775`*^9, 3.767963477607958*^9}, {
  3.7679639630749483`*^9, 
  3.7679640094637246`*^9}},ExpressionUUID->"e4ebcb6a-18a3-47a9-b901-\
884442e8d2df"]
}, Open  ]]
}, Closed]]
}, Closed]],

Cell[CellGroupData[{

Cell["Testing", "Section",
 CellChangeTimes->{{3.7695199931853857`*^9, 3.769519994387024*^9}, {
  3.769529487894743*^9, 
  3.769529488202163*^9}},ExpressionUUID->"e5058cfc-4eb7-4002-a159-\
4b63f2d253ff"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Define", " ", "the", " ", "quark", " ", "spatial", " ", "correlation", 
    " ", "function"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"corr", "[", 
      RowBox[{"r_", ",", "\[Alpha]_", ",", "m_", ",", "Q_"}], "]"}], ":=", 
     RowBox[{"r", "*", 
      FractionBox[
       SuperscriptBox["m", "2"], 
       RowBox[{"8", 
        SuperscriptBox["\[Pi]", "2"]}]], "*", 
      SuperscriptBox[
       RowBox[{"(", "GeVfm", ")"}], "2"], 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{"Exp", "[", 
         RowBox[{
          FractionBox[
           RowBox[{"-", "1"}], "4"], 
          RowBox[{"(", 
           RowBox[{
            SuperscriptBox["\[Alpha]", "2"], "+", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"1", "-", "\[Alpha]"}], ")"}], "2"]}], ")"}], 
          SuperscriptBox[
           RowBox[{"(", "GeVfm", ")"}], "2"], 
          SuperscriptBox["r", "2"], " ", 
          SuperscriptBox["Q", "2"]}], "]"}]}], ")"}], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           SuperscriptBox["\[Alpha]", "2"], "+", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"1", "-", "\[Alpha]"}], ")"}], "2"]}], ")"}], 
         SuperscriptBox[
          RowBox[{"BesselK", "[", 
           RowBox[{"1", ",", 
            RowBox[{
             RowBox[{"(", "GeVfm", ")"}], "m", " ", "r"}]}], "]"}], "2"]}], 
        "+", 
        SuperscriptBox[
         RowBox[{"BesselK", "[", 
          RowBox[{"0", ",", " ", 
           RowBox[{
            RowBox[{"(", "GeVfm", ")"}], "m", " ", "r"}]}], "]"}], "2"]}], 
       ")"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"bound", "[", 
     RowBox[{"\[Alpha]_", ",", "Q_"}], "]"}], ":=", 
    RowBox[{"(", 
     RowBox[{"1.2", "*", 
      FractionBox[
       RowBox[{
        SuperscriptBox["Q", "2"], " ", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{"2", " ", "\[Alpha]"}], "+", 
           RowBox[{"2", " ", 
            SuperscriptBox["\[Alpha]", "2"]}]}], ")"}], "2"]}], 
       RowBox[{"32", " ", 
        SuperscriptBox["\[Pi]", "2"]}]]}], ")"}]}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"MCfail", "="}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Print", "@", 
    RowBox[{"Plot3D", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"corr", "[", 
         RowBox[{"r", ",", "\[Alpha]", ",", "0.095", ",", "1"}], "]"}], ",", 
        RowBox[{"bound", "[", 
         RowBox[{"\[Alpha]", ",", "1"}], "]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"r", ",", "0", ",", "2"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Alpha]", ",", "0", ",", "1"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"AxesLabel", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
        "\"\<r\>\"", ",", "\"\<\[Alpha]\>\"", ",", "\"\<P(\[Alpha],r)\>\""}], 
        "}"}]}], ",", 
      RowBox[{"ImageSize", "\[Rule]", "500"}], ",", 
      RowBox[{"LabelStyle", "\[Rule]", 
       RowBox[{"Directive", "[", 
        RowBox[{"18", ",", "Black"}], "]"}]}], ",", 
      RowBox[{
      "PlotLabel", "\[Rule]", "\"\<Strange Quarks, Qs = 1 GeV\>\""}]}], 
     "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "SetDirectory", "[", "\"\<C:\\\\Users\\\\sieve\\\\Dropbox\\\\ICCING\>\"",
       "]"}], "\[IndentingNewLine]", 
     RowBox[{"Export", "[", 
      RowBox[{"\"\<MC_Failure.pdf\>\"", ",", "MCfail"}], "]"}]}], 
    "*)"}]}]}]], "Input",
 CellChangeTimes->{{3.7683047933328714`*^9, 3.76830481812436*^9}, 
   3.7683066494485097`*^9, {3.768306996049288*^9, 3.768307000458753*^9}, {
