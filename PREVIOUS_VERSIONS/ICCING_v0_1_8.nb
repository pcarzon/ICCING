                  "\[IndentingNewLine]", "\t\t\t", "]"}]}]}], 
               "\[IndentingNewLine]", "\t\t", "]"}], ";"}], 
             "\[IndentingNewLine]", "\t", ",", "\[IndentingNewLine]", "\t\t", 
             RowBox[{
              RowBox[{"mytext", "=", "\"\<Remains a gluon; copying\>\""}], 
              ";", "\[IndentingNewLine]", "\t\t", 
              RowBox[{"(*", " ", 
               RowBox[{
                RowBox[{
                "If", " ", "the", " ", "outcome", " ", "remains", " ", "a", 
                 " ", "gluon"}], ",", " ", 
                RowBox[{
                "then", " ", "transfer", " ", "the", " ", "energy", " ", 
                 "over", " ", "proportionally"}]}], " ", "*)"}], 
              "\[IndentingNewLine]", "\t\t", 
              RowBox[{"For", "[", 
               RowBox[{
                RowBox[{"k", "=", "1"}], ",", 
                RowBox[{"k", "\[LessEqual]", 
                 RowBox[{"Length", "[", "circlist", "]"}]}], ",", 
                RowBox[{"k", "++"}], ",", "\[IndentingNewLine]", "\t\t", 
                RowBox[{
                 RowBox[{"ival", "=", 
                  SubscriptBox["circlist", 
                   RowBox[{"\[LeftDoubleBracket]", 
                    RowBox[{"k", ",", "1"}], "\[RightDoubleBracket]"}]]}], 
                 ";", "\[IndentingNewLine]", "\t\t", 
                 RowBox[{"jval", "=", 
                  SubscriptBox["circlist", 
                   RowBox[{"\[LeftDoubleBracket]", 
                    RowBox[{"k", ",", "2"}], "\[RightDoubleBracket]"}]]}], 
                 ";", "\[IndentingNewLine]", "\t\t", 
                 RowBox[{"\[CapitalDelta]E", "=", 
                  RowBox[{
                   FractionBox["Eglue", "Etot"], 
                   SubscriptBox["myEN", 
                    RowBox[{"\[LeftDoubleBracket]", 
                    RowBox[{"ival", ",", "jval"}], 
                    "\[RightDoubleBracket]"}]]}]}], ";", 
                 "\[IndentingNewLine]", "\t\t", 
                 RowBox[{
                  SubscriptBox["NewENgrid", 
                   RowBox[{"\[LeftDoubleBracket]", 
                    RowBox[{"ival", ",", "jval"}], "\[RightDoubleBracket]"}]],
                   "+=", "\[CapitalDelta]E"}], ";", "\[IndentingNewLine]", 
                 "\t\t", 
                 RowBox[{
                  SubscriptBox["myEN", 
                   RowBox[{"\[LeftDoubleBracket]", 
                    RowBox[{"ival", ",", "jval"}], "\[RightDoubleBracket]"}]],
                   "-=", "\[CapitalDelta]E"}], ";"}]}], "\[IndentingNewLine]",
                "\t\t", "]"}], ";"}]}], "\[IndentingNewLine]", "\t", "]"}], 
           ";"}]}], "  ", 
         RowBox[{"(*", " ", 
          RowBox[{"End", " ", 
           RowBox[{"If", "[", "IsQuark", "]"}]}], " ", "*)"}], 
         "\[IndentingNewLine]", "\t", "\[IndentingNewLine]", "]"}], ";", "  ", 
        RowBox[{"(*", " ", 
         RowBox[{"End", " ", "Which"}], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"len", "=", 
         RowBox[{
          RowBox[{"Length", "[", 
           RowBox[{"ArrayRules", "[", "myEN", "]"}], "]"}], "-", "1"}]}], ";",
         "\[IndentingNewLine]", 
        RowBox[{"AppendTo", "[", 
         RowBox[{"images", ",", 
          RowBox[{"MakePlot", "[", 
           RowBox[{
           "NewENgrid", ",", "NewNBGrid", ",", "NewNSGrid", ",", "NewNQGrid", 
            ",", "legendpos", ",", "labelpos", ",", "False"}], "]"}]}], "]"}],
         ";", "\[IndentingNewLine]", 
        RowBox[{"numframes", "++"}], ";"}]}], "\[IndentingNewLine]", 
      "\[IndentingNewLine]", "]"}], ";"}]}], "  ", 
   RowBox[{"(*", " ", 
    RowBox[{"End", " ", "While"}], " ", "*)"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", "]"}]}]], "Input",
