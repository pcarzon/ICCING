Cell[TextData[{
 StyleBox["\nThe peak is highest for ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Alpha]", "=", "0"}], TraditionalForm]],
  FormatType->"TraditionalForm",
  FontWeight->"Bold",ExpressionUUID->"512998b5-b946-44f5-8da2-d939965ad626"],
 StyleBox[" or ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Alpha]", "=", "1"}], TraditionalForm]],
  FormatType->"TraditionalForm",
  FontWeight->"Bold",ExpressionUUID->"d9a913c3-43a0-4586-90d1-0fc0f9e9f563"],
 StyleBox[", and it does seem to move around as a function of \[Alpha].\n\n\
For given values of ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"m", ",", " ", 
     SubscriptBox["Q", "s"]}], ")"}], TraditionalForm]],
  FormatType->"TraditionalForm",
  FontWeight->"Bold",ExpressionUUID->"4c21ef4c-3a14-4f3a-988a-102002914410"],
 StyleBox[", the absolute maximum occurs at ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Alpha]", "=", "0"}], TraditionalForm]],
  FormatType->"TraditionalForm",
  FontWeight->"Bold",ExpressionUUID->"c916b9a0-c492-44bc-830b-c84ab2a58920"],
 ", so we\[CloseCurlyQuote]ll use this value to get the peak height at its \
highest point.",
 StyleBox["\n\n\n\nHow does the maximum depend on ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   SubscriptBox["Q", "s"], TraditionalForm]],
  FormatType->"TraditionalForm",
  FontWeight->"Bold",ExpressionUUID->"1dd8a6c8-c261-4092-a88a-d320be1b03a2"],
 StyleBox[" ?\n\n",
  FontWeight->"Bold"],
 "Since the peak moves around considerably with ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["Q", "s"], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "85a7bbd3-fd44-4c14-8983-231e89e3e16a"],
 " we need to do a little better with the root finder:",
 StyleBox["\n",
  FontWeight->"Bold"]
}], "Text",
 CellChangeTimes->{{3.8025284445422187`*^9, 3.8025284847806845`*^9}, {
  3.802528740892324*^9, 3.8025288181933794`*^9}, {3.802531347257676*^9, 
  3.802531356492985*^9}, {3.8025314293852205`*^9, 3.802531455293917*^9}, {
  3.8025409907684627`*^9, 3.802541038109027*^9}},
 FontColor->RGBColor[
  0, 0, 1],ExpressionUUID->"3364c1bb-77ec-4539-bf2d-3cbd7f6e0b3c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"findmax3", "[", 
   RowBox[{"\[Alpha]_", ",", "m_", ",", "Q_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "temp1", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"temp1", "=", 
      RowBox[{"FindMaximum", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"corr", "[", 
           RowBox[{"r", ",", "\[Alpha]", ",", "m", ",", "Q"}], "]"}], ",", 
          RowBox[{"0", "<", "r", "<", "rmax"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"r", ",", "0.2"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"r", "/.", 
         SubscriptBox["temp1", 
          RowBox[{"\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]]}], 
        ",", 
        SubscriptBox["temp1", 
         RowBox[{"\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]]}], 
       "}"}], "]"}]}]}], "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.8025298986553407`*^9, 3.8025299220134344`*^9}, {
