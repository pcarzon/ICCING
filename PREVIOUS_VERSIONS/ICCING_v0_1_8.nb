Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Define", " ", "Monte", " ", "Carlo", " ", "sampling", " ", "of", " ", 
     "the", " ", "3", "D", " ", "Woods"}], "-", 
    RowBox[{"Saxon", " ", 
     RowBox[{"Distribution", " ", "--"}], " ", "valid", " ", "only", " ", 
     "for", " ", "spherical", " ", "nuclei"}]}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"f", "[", "r_", "]"}], " ", "=", " ", 
      RowBox[{
       RowBox[{"r", "^", "2"}], 
       RowBox[{"n0", "/", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"r", "-", "Rn"}], ")"}], "/", "d"}], "]"}]}], 
         ")"}]}]}]}], ";"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"fp", "[", "r_", "]"}], "=", 
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"f", "[", "r", "]"}], ",", "r"}], "]"}]}], ";"}], 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"fmax", " ", "=", " ", 
      RowBox[{
       RowBox[{"f", "[", "r", "]"}], " ", "/.", " ", 
       RowBox[{"FindRoot", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"fp", "[", "r", "]"}], "\[Equal]", "0"}], ",", 
         RowBox[{"{", 
          RowBox[{"r", ",", "5"}], "}"}]}], "]"}]}]}], ";"}], 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Clear", "[", "rejectionSample", "]"}], ";"}], 
    "\[IndentingNewLine]", 
    RowBox[{"rejectionSample", "[", "N_", "]"}]}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"o", ",", "x", ",", "u"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"o", " ", "=", " ", 
       RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Length", "[", "o", "]"}], "<", "N"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"x", " ", "=", " ", 
          RowBox[{"RandomReal", "[", 
           RowBox[{"{", 
            RowBox[{"0", ",", "20"}], "}"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"u", " ", "=", " ", 
          RowBox[{"RandomReal", "[", "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"u", "<", 
            RowBox[{
             RowBox[{"f", "[", "x", "]"}], "/", 
             RowBox[{"(", 
              RowBox[{"1.01", "*", "fmax"}], ")"}]}]}], ",", 
           RowBox[{"o", " ", "=", " ", 
            RowBox[{"Append", "[", 
             RowBox[{"o", ",", "x"}], "]"}]}]}], "]"}], ";"}]}], 
       "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Return", "[", "o", "]"}], ";"}]}], "\[IndentingNewLine]", 
    "]"}]}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Returns", " ", "a", " ", "list", " ", "of", " ", "N", " ", "radii", " ", 
     RowBox[{"{", 
      RowBox[{"r1", ",", " ", "r2", ",", " ", 
       RowBox[{"...", " ", "rN"}]}], "}"}], " ", "sampled", " ", "from", " ", 
     "the", " ", "3", "D", " ", "Woods"}], "-", "Saxon"}], " ", "*)"}], 
  "*)"}]], "Input",
 CellChangeTimes->{{3.7682321259415226`*^9, 3.7682321762314444`*^9}, {
  3.768303898789508*^9, 3.7683039008600945`*^9}, {3.768304411909771*^9, 
  3.7683044420657*^9}},
