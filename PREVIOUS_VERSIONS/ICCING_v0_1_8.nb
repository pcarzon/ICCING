                    SuperscriptBox["qirad", "2"]}]]}], "]"}]}]}], ";", 
                    "\[IndentingNewLine]", "\t\t\t\t", 
                    RowBox[{
                    SubscriptBox["NewCBarGrid", 
                    RowBox[{"\[LeftDoubleBracket]", 
                    RowBox[{"qbarival", ",", "qbarjval"}], 
                    "\[RightDoubleBracket]"}]], "+=", 
                    RowBox[{
                    FractionBox["1", 
                    RowBox[{"qtotal", "*", "dx", "*", "dy", "*", "\[Tau]0"}]],
                     "*", 
                    RowBox[{"Exp", "[", 
                    RowBox[{"-", 
                    FractionBox[
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
