Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Calculate", " ", "just", " ", "the", " ", "needed", " ", "eccentricities",
     " ", "of", " ", "a", " ", "discrete", " ", "distribution"}], " ", "*)"}],
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"ecc2", "[", "matx_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "num1", ",", "den1", ",", "E1", ",", "num2", ",", "den2", ",", "E2", 
        ",", "num3", ",", "den3", ",", "E3", ",", "tot", ",", "icom", ",", 
        "jcom"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"tot", "=", 
        RowBox[{"Sum", "[", 
         RowBox[{
          SubscriptBox["matx", 
           RowBox[{"\[LeftDoubleBracket]", 
            RowBox[{"i", ",", "j"}], "\[RightDoubleBracket]"}]], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "imax"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", "1", ",", "jmax"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"tot", ">", "0"}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{"icom", ",", "jcom"}], "}"}], "=", 
           RowBox[{
            FractionBox["1", "tot"], 
            RowBox[{"Sum", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"i", "*", 
                 SubscriptBox["matx", 
                  RowBox[{"\[LeftDoubleBracket]", 
                   RowBox[{"i", ",", "j"}], "\[RightDoubleBracket]"}]]}], ",", 
                RowBox[{"j", "*", 
                 SubscriptBox["matx", 
                  RowBox[{"\[LeftDoubleBracket]", 
                   RowBox[{"i", ",", "j"}], "\[RightDoubleBracket]"}]]}]}], 
               "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"i", ",", "1", ",", "imax"}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"j", ",", "1", ",", "jmax"}], "}"}]}], "]"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"num2", "=", 
           RowBox[{"Sum", "[", 
            RowBox[{
             RowBox[{
              SuperscriptBox[
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"i", " ", "dx"}], "-", 
                   RowBox[{"icom", " ", "dx"}]}], ")"}], "+", 
                 RowBox[{"\[ImaginaryI]", 
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"j", " ", "dy"}], "-", 
                    RowBox[{"jcom", " ", "dy"}]}], ")"}]}]}], ")"}], "2"], 
              "*", " ", 
              SubscriptBox["matx", 
               RowBox[{"\[LeftDoubleBracket]", 
                RowBox[{"i", ",", "j"}], "\[RightDoubleBracket]"}]]}], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "1", ",", "imax"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"j", ",", "1", ",", "jmax"}], "}"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"den2", "=", 
           RowBox[{"Sum", "[", 
            RowBox[{
             RowBox[{
              SuperscriptBox[
               RowBox[{"(", 
                RowBox[{
                 SuperscriptBox[
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"i", " ", "dx"}], "-", 
                    RowBox[{"icom", " ", "dx"}]}], ")"}], "2"], "+", 
                 SuperscriptBox[
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"j", " ", "dy"}], "-", 
                    RowBox[{"jcom", " ", "dy"}]}], ")"}], "2"]}], ")"}], 
               RowBox[{"2", "/", "2"}]], " ", "*", " ", 
              SubscriptBox["matx", 
               RowBox[{"\[LeftDoubleBracket]", 
                RowBox[{"i", ",", "j"}], "\[RightDoubleBracket]"}]]}], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "1", ",", "imax"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"j", ",", "1", ",", "jmax"}], "}"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"E2", "=", 
           RowBox[{"AbsArg", "[", 
            FractionBox[
             RowBox[{"-", "num2"}], "den2"], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"num3", "=", 
           RowBox[{"Sum", "[", 
            RowBox[{
             RowBox[{
              SuperscriptBox[
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"i", " ", "dx"}], "-", 
                   RowBox[{"icom", " ", "dx"}]}], ")"}], "+", 
                 RowBox[{"\[ImaginaryI]", 
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"j", " ", "dy"}], "-", 
                    RowBox[{"jcom", " ", "dy"}]}], ")"}]}]}], ")"}], "3"], 
              "*", " ", 
              SubscriptBox["matx", 
               RowBox[{"\[LeftDoubleBracket]", 
                RowBox[{"i", ",", "j"}], "\[RightDoubleBracket]"}]]}], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "1", ",", "imax"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"j", ",", "1", ",", "jmax"}], "}"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"den3", "=", 
           RowBox[{"Sum", "[", 
            RowBox[{
             RowBox[{
              SuperscriptBox[
               RowBox[{"(", 
                RowBox[{
                 SuperscriptBox[
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"i", " ", "dx"}], "-", 
                    RowBox[{"icom", " ", "dx"}]}], ")"}], "2"], "+", 
                 SuperscriptBox[
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"j", " ", "dy"}], "-", 
                    RowBox[{"jcom", " ", "dy"}]}], ")"}], "2"]}], ")"}], 
               RowBox[{"3", "/", "2"}]], " ", "*", " ", 
              SubscriptBox["matx", 
               RowBox[{"\[LeftDoubleBracket]", 
                RowBox[{"i", ",", "j"}], "\[RightDoubleBracket]"}]]}], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "1", ",", "imax"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"j", ",", "1", ",", "jmax"}], "}"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"E3", "=", 
           RowBox[{"AbsArg", "[", 
            FractionBox[
             RowBox[{"-", "num3"}], "den3"], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"icom", ",", "jcom"}], "}"}], ",", "E2", ",", "E3"}], 
           "}"}]}], "         ", 
         RowBox[{"(*", " ", 
          RowBox[{
          "Returns", " ", "CMS", " ", "position", " ", "magnitudes", " ", 
           "and", " ", "angles", " ", 
           RowBox[{"{", " ", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"i_CMS", ",", " ", "j_CMS"}], "}"}], ",", " ", 
             RowBox[{"{", 
              RowBox[{"\[Epsilon]2", ",", " ", "\[Psi]2"}], "}"}], " ", ",", 
             " ", 
             RowBox[{"{", 
              RowBox[{"\[Epsilon]3", ",", " ", "\[Psi]3"}], "}"}]}], " ", 
            "}"}]}], " ", "*)"}], "\[IndentingNewLine]", ",", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
          "Print", "[", 
           "\"\<Empty matrix encountered; cannot compute eccentricities\>\"", 
           "]"}], ";", "\[IndentingNewLine]", 
          RowBox[{"Return", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"0", ",", "0"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"0", ",", "0"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"0", ",", "0"}], "}"}]}], "}"}], "]"}], ";"}]}], 
        "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", "]"}]}], 
   "*)"}]}]], "Input",
