        "\[IndentingNewLine]", "k", ",", "\[IndentingNewLine]", "qpt", ",", 
       "\[IndentingNewLine]", "qbarpt", ",", "\[IndentingNewLine]", 
       "qcirclist", ",", "\[IndentingNewLine]", "qbarcirclist", ",", 
       "\[IndentingNewLine]", "qtotal", ",", "\[IndentingNewLine]", 
       "qbartotal", ",", "\[IndentingNewLine]", "qival", ",", 
       "\[IndentingNewLine]", "qjval", ",", "\[IndentingNewLine]", "qbarival",
        ",", "\[IndentingNewLine]", "qbarjval", ",", "\[IndentingNewLine]", 
       "\[CapitalDelta]E", ",", "\[IndentingNewLine]", "mytext", ",", 
       "\[IndentingNewLine]", "NBtotal", ",", "\[IndentingNewLine]", 
       "NStotal", ",", "\[IndentingNewLine]", "NQtotal", ",", 
       "\[IndentingNewLine]", "Uptotal", ",", "\[IndentingNewLine]", 
       "UBartotal", ",", "\[IndentingNewLine]", "Downtotal", ",", 
       "\[IndentingNewLine]", "DBartotal", ",", "\[IndentingNewLine]", 
       "Strangetotal", ",", "\[IndentingNewLine]", "SBartotal", ",", 
       "\[IndentingNewLine]", "Charmtotal", ",", "\[IndentingNewLine]", 
       "CBartotal"}], "\[IndentingNewLine]", "\[IndentingNewLine]", "}"}], 
     ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"status", "=", "\"\<Redistributing quarks\>\""}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "Convert", " ", "the", " ", "quark", " ", "and", " ", "gluon", " ", 
        "radii", " ", "into", " ", "lattice", " ", "units"}], " ", "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"irad", "=", 
       RowBox[{"Round", "[", 
        FractionBox["rad", "dx"], "]"}]}], ";", "   ", 
      RowBox[{"(*", " ", 
       RowBox[{"Gluon", " ", "radius"}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"qirad", "=", 
       RowBox[{"Round", "[", 
        FractionBox["qrad", "dx"], "]"}]}], ";", "  ", 
      RowBox[{"(*", " ", 
       RowBox[{"Quark", " ", "radius"}], " ", "*)"}], "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "These", " ", "are", " ", "variables", " ", "to", " ", "monitor", " ", 
        "the", " ", "progress", " ", "through", " ", "the", " ", 
        "algorithm"}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"len", "=", 
       RowBox[{
        RowBox[{"Length", "[", 
         RowBox[{"ArrayRules", "[", "myEN", "]"}], "]"}], "-", "1"}]}], ";", 
      "    ", 
      RowBox[{"(*", " ", 
       RowBox[{
       "Number", " ", "of", " ", "points", " ", "with", " ", "nonzero", " ", 
        "energy", " ", "density", " ", "in", " ", "the", " ", "input", " ", 
        "array"}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"Einitial", "=", 
       RowBox[{
        RowBox[{"Sum", "[", 
         RowBox[{
          SubscriptBox["myEN", 
           RowBox[{"\[LeftDoubleBracket]", 
            RowBox[{"i", ",", "j"}], "\[RightDoubleBracket]"}]], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "imax"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", "1", ",", "jmax"}], "}"}]}], "]"}], "*", 
        "\[Tau]0", "*", "dx", "*", "dy"}]}], ";", "  ", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{
        "Total", " ", "energy", " ", "contained", " ", "in", " ", "the", " ", 
         "input", " ", "array"}], ",", " ", 
        RowBox[{
        "in", " ", "GeV", " ", "per", " ", "unit", " ", "rapidity"}]}], " ", 
       "*)"}], "\[IndentingNewLine]", 
      RowBox[{"Einput", "=", "Einitial"}], ";", "  ", 
      RowBox[{"(*", " ", 
       RowBox[{
       "Total", " ", "energy", " ", "which", " ", "has", " ", "not", " ", 
        "been", " ", "redistributed", " ", "yet", " ", "by", " ", "the", " ", 
        "algorithm"}], "  ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"Eoutput", "=", "0"}], ";", "  ", 
      RowBox[{"(*", " ", 
       RowBox[{
       "Total", " ", "energy", " ", "which", " ", "has", " ", "already", " ", 
        "been", " ", "redistributed", " ", "by", " ", "the", " ", 
        "algorithm"}], " ", "*)"}], "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
