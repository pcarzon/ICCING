Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Define", " ", "the", " ", "quark", " ", "spatial", " ", "correlation", 
    " ", "function"}], " ", "*)"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{"dipole", "\[Equal]", "\"\<MV\>\""}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"corr", "[", 
       RowBox[{"r_", ",", "\[Alpha]_", ",", "m_", ",", "Q_"}], "]"}], ":=", 
      RowBox[{"r", "*", 
       FractionBox[
        SuperscriptBox["m", "2"], 
        RowBox[{"8", 
         SuperscriptBox["\[Pi]", "2"]}]], "*", 
       SuperscriptBox[
        RowBox[{"(", "GeVfm", ")"}], "2"], 
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"Exp", "[", 
          RowBox[{
           FractionBox[
            RowBox[{"-", "1"}], "4"], 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              SuperscriptBox["\[Alpha]", "2"], 
              RowBox[{"Log", "[", 
               FractionBox["1", 
                RowBox[{"\[Alpha]", 
                 RowBox[{"(", "GeVfm", ")"}], "r", " ", "m", " ", 
                 RowBox[{"(", "\[CapitalLambda]bym", ")"}]}]], "]"}]}], "+", 
             RowBox[{
              SuperscriptBox[
               RowBox[{"(", 
                RowBox[{"1", "-", "\[Alpha]"}], ")"}], "2"], 
              RowBox[{"Log", "[", 
               FractionBox["1", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"1", "-", "\[Alpha]"}], ")"}], 
                 RowBox[{"(", "GeVfm", ")"}], "r", " ", "m", " ", 
                 RowBox[{"(", "\[CapitalLambda]bym", ")"}]}]], "]"}]}]}], 
            ")"}], 
           SuperscriptBox[
            RowBox[{"(", "GeVfm", ")"}], "2"], 
           SuperscriptBox["r", "2"], " ", 
           SuperscriptBox["Q", "2"]}], "]"}]}], ")"}], 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            SuperscriptBox["\[Alpha]", "2"], "+", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"1", "-", "\[Alpha]"}], ")"}], "2"]}], ")"}], 
          SuperscriptBox[
           RowBox[{"BesselK", "[", 
            RowBox[{"1", ",", 
             RowBox[{
              RowBox[{"(", "GeVfm", ")"}], "m", " ", "r"}]}], "]"}], "2"]}], 
         "+", 
         SuperscriptBox[
          RowBox[{"BesselK", "[", 
           RowBox[{"0", ",", " ", 
            RowBox[{
             RowBox[{"(", "GeVfm", ")"}], "m", " ", "r"}]}], "]"}], "2"]}], 
        ")"}]}]}], ";"}], "\[IndentingNewLine]", ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"corr", "[", 
       RowBox[{"r_", ",", "\[Alpha]_", ",", "m_", ",", "Q_"}], "]"}], ":=", 
      RowBox[{"r", "*", 
       FractionBox[
        SuperscriptBox["m", "2"], 
        RowBox[{"8", 
         SuperscriptBox["\[Pi]", "2"]}]], "*", 
       SuperscriptBox[
        RowBox[{"(", "GeVfm", ")"}], "2"], 
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"Exp", "[", 
          RowBox[{
           FractionBox[
            RowBox[{"-", "1"}], "4"], 
           RowBox[{"(", 
            RowBox[{
             SuperscriptBox["\[Alpha]", "2"], "+", 
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{"1", "-", "\[Alpha]"}], ")"}], "2"]}], ")"}], 
           SuperscriptBox[
            RowBox[{"(", "GeVfm", ")"}], "2"], 
           SuperscriptBox["r", "2"], " ", 
           SuperscriptBox["Q", "2"]}], "]"}]}], ")"}], 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            SuperscriptBox["\[Alpha]", "2"], "+", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"1", "-", "\[Alpha]"}], ")"}], "2"]}], ")"}], 
          SuperscriptBox[
           RowBox[{"BesselK", "[", 
            RowBox[{"1", ",", 
             RowBox[{
              RowBox[{"(", "GeVfm", ")"}], "m", " ", "r"}]}], "]"}], "2"]}], 
         "+", 
         SuperscriptBox[
          RowBox[{"BesselK", "[", 
           RowBox[{"0", ",", " ", 
            RowBox[{
             RowBox[{"(", "GeVfm", ")"}], "m", " ", "r"}]}], "]"}], "2"]}], 
        ")"}]}]}], ";"}]}], "\[IndentingNewLine]", "]"}]}]], "Input",
