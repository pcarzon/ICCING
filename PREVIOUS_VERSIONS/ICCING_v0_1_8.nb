    "this", " ", "routine", " ", "reads", " ", "in", " ", "the", " ", 
     "relevant", " ", "files", " ", "for", " ", "the", " ", "TB", " ", 
     "profile", " ", "and", " ", "TR", " ", "profile", " ", "and", " ", 
     "uses", " ", "them", " ", "to", " ", "construct", " ", "the", " ", 
     "sparse", " ", "arrays", " ", "for", " ", "Qs"}], ",", " ", 
    RowBox[{"the", " ", "energy", " ", "density"}], ",", " ", 
    RowBox[{
    "and", " ", "a", " ", "discretezed", " ", "energy", " ", "density", " ", 
     "used", " ", "as", " ", "a", " ", "proxy", " ", "for", " ", "the", " ", 
     "number", " ", "of", " ", "gluons"}]}], "\[IndentingNewLine]", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ReadTrento", "[", 
