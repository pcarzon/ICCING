           SubscriptBox["mydata", 
            RowBox[{
            "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]]]}], 
         "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"jmax", "=", 
       RowBox[{"Round", "@", 
        RowBox[{"Abs", "[", 
         RowBox[{"2", "*", 
          FractionBox[
           SubscriptBox["mydata", 
            RowBox[{"\[LeftDoubleBracket]", "6", "\[RightDoubleBracket]"}]], 
           SubscriptBox["mydata", 
            RowBox[{
            "\[LeftDoubleBracket]", "3", "\[RightDoubleBracket]"}]]]}], 
         "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"mysparseTA", "=", 
       RowBox[{"SparseArray", "[", 
