Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "New", " ", "procedure", " ", "for", " ", "the", " ", "splitting", " ", 
    RowBox[{"MC", ".", "  ", "The"}], " ", "old", " ", "one", " ", "used", 
    " ", "the", " ", "wrong", " ", "MC", " ", "ceiling"}], " ", "*)"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"SplittingSample", "[", "Qs_", "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"MCceiling", ",", "charges", ",", "m", ",", "IsQuark", ",", 
       RowBox[{"o", "=", 
        RowBox[{"{", "}"}]}], ",", "r", ",", "y", ",", "\[Alpha]temp", ",", 
       RowBox[{"rfinal", "=", "\"\<\>\""}], ",", 
       RowBox[{"\[Phi]", "=", 
        RowBox[{"RandomReal", "[", 
         RowBox[{"{", 
          RowBox[{"0", ",", 
           RowBox[{"2", "\[Pi]"}]}], "}"}], "]"}]}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"charges", "=", 
       RowBox[{"RollFlavor", "[", "Qs", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"m", "=", 
       SubscriptBox["charges", 
        RowBox[{"\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"IsQuark", "=", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          SubscriptBox["charges", 
           RowBox[{"\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]], 
          "\[NotEqual]", "\"\<g\>\""}], ",", "True", ",", "False"}], "]"}]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{"IsQuark", ",", "\[IndentingNewLine]", 
        RowBox[{"While", "[", 
         RowBox[{
          RowBox[{"rfinal", "\[Equal]", "\"\<\>\""}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"r", " ", "=", " ", 
            RowBox[{"RandomReal", "[", 
             RowBox[{"{", 
              RowBox[{"0", ",", "rmax"}], "}"}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"\[Alpha]temp", "=", 
            RowBox[{"RandomReal", "[", 
             RowBox[{"{", 
              RowBox[{"\[Alpha]min", ",", 
               RowBox[{"1", "-", "\[Alpha]min"}]}], "}"}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"MCceiling", "=", 
            RowBox[{"1.01", "*", 
             SubscriptBox[
              RowBox[{"FindMaximum", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"corr", "[", 
                   RowBox[{"r", ",", "0", ",", "m", ",", "Qs"}], "]"}], ",", 
                  RowBox[{"0", "<", "r", "<", "rmax"}]}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{"r", ",", "0.2"}], "}"}]}], "]"}], 
              RowBox[{
              "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]]}]}], 
           ";", "\[IndentingNewLine]", 
           RowBox[{"y", " ", "=", " ", 
            RowBox[{"RandomReal", "[", 
             RowBox[{"{", 
              RowBox[{"0", ",", "MCceiling"}], "}"}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"y", "<", 
              RowBox[{"corr", "[", 
               RowBox[{"r", ",", "\[Alpha]temp", ",", "m", ",", "Qs"}], 
               "]"}]}], ",", 
             RowBox[{"rfinal", "=", "r"}]}], "]"}], ";"}]}], 
         "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Return", "[", 
          RowBox[{"{", 
           RowBox[{"charges", ",", 
            RowBox[{"{", 
             RowBox[{"1", ",", "0", ",", "0"}], "}"}]}], "}"}], "]"}], 
         ";"}]}], "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Return", "[", 
       RowBox[{"{", 
        RowBox[{"charges", ",", 
         RowBox[{"{", 
          RowBox[{"\[Alpha]temp", ",", 
           RowBox[{"rfinal", " ", 
            RowBox[{"Cos", "[", "\[Phi]", "]"}]}], ",", 
           RowBox[{"rfinal", " ", 
            RowBox[{"Sin", "[", "\[Phi]", "]"}]}]}], "}"}]}], "}"}], 
       "]"}]}]}], "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{
      RowBox[{
      "Returns", " ", "the", " ", "charges", " ", "of", " ", "the", " ", 
       "selected", " ", "flavor"}], ",", " ", 
      RowBox[{
      "the", " ", "fraction", " ", "of", " ", "energy", " ", "being", " ", 
       "redistributed"}], ",", " ", 
      RowBox[{"and", " ", "the", " ", 
       RowBox[{"displacement", ":", "  ", 
        RowBox[{"{", " ", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"f", ",", "m", ",", "b", ",", "s", ",", "q"}], "}"}], " ", 
          ",", " ", 
          RowBox[{"{", 
           RowBox[{
           "\[Alpha]", ",", "\[CapitalDelta]x", ",", "\[CapitalDelta]y"}], 
           "}"}]}], " ", "}"}]}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
    "]"}], "  "}]}]], "Input",
 CellChangeTimes->{{3.768234724840887*^9, 3.768234755052925*^9}, {
   3.7682348838536887`*^9, 3.7682349244327316`*^9}, {3.768235011565856*^9, 
   3.7682350200774107`*^9}, 3.768304782220622*^9, 3.768304839145446*^9, {
   3.8025445798656044`*^9, 3.802544759027027*^9}, {3.8025447955724063`*^9, 
   3.8025449687734528`*^9}, {3.8025450078456182`*^9, 
   3.8025450139765573`*^9}, {3.802606833544387*^9, 3.802606869393509*^9}, {
   3.8026138648928523`*^9, 
   3.8026138899259143`*^9}},ExpressionUUID->"f5dcd75d-3c9c-435a-9b84-\
