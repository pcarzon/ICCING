     RowBox[{
      RowBox[{"mytb", "=", 
       RowBox[{"Import", "[", "TBFile", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"mytr", "=", 
       RowBox[{"Import", "[", "TRFile", "]"}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "eventnum", ",", "dx", ",", "dy", ",", "Stot", ",", "xmin", ",", 
         "ymin"}], "}"}], "=", 
       SubscriptBox["mytb", 
        RowBox[{"\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"PrintTemporary", "[", 
       RowBox[{"\"\<Processing TRENTO Event #\>\"", "<>", 
        RowBox[{"ToString", "[", "eventnum", "]"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"imax", "=", 
       RowBox[{"Round", "@", 
        RowBox[{"Abs", "[", 
         RowBox[{"2", "*", 
          FractionBox["xmin", "dx"]}], "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"jmax", "=", 
       RowBox[{"Round", "@", 
        RowBox[{"Abs", "[", 
         RowBox[{"2", "*", 
          FractionBox["ymin", "dy"]}], "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"myQsgrid", "=", 
       RowBox[{"Map", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            FractionBox[
             RowBox[{
              SubscriptBox["#", 
               RowBox[{
               "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]], "-", 
              "xmin"}], "dx"], ",", 
            FractionBox[
             RowBox[{
              SubscriptBox["#", 
               RowBox[{
               "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]], "-", 
              "ymin"}], "dy"], ",", 
            RowBox[{"\[Kappa]", "*", 
             SqrtBox[
              SubscriptBox["#", 
               RowBox[{
               "\[LeftDoubleBracket]", "3", "\[RightDoubleBracket]"}]]]}]}], 
           "}"}], "&"}], ",", 
         RowBox[{"Delete", "[", 
          RowBox[{"mytb", ",", "1"}], "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"mysparseQs", "=", 
       RowBox[{"SparseArray", "[", 
        RowBox[{
         RowBox[{"Map", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"Round", "[", 
                SubscriptBox["#", 
                 RowBox[{
                 "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]], 
                "]"}], ",", 
               RowBox[{"Round", "[", 
                SubscriptBox["#", 
                 RowBox[{
                 "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]], 
                "]"}]}], "}"}], "\[Rule]", 
             SubscriptBox["#", 
              RowBox[{
              "\[LeftDoubleBracket]", "3", "\[RightDoubleBracket]"}]]}], 
            "&"}], ",", "myQsgrid"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"imax", ",", "jmax"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"mytrgrid", "=", 
       RowBox[{"Map", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            FractionBox[
             RowBox[{
              SubscriptBox["#", 
               RowBox[{
               "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]], "-", 
