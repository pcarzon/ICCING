       RowBox[{"ConvertTrento", "[", "mysparseTR", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"myEtot", "=", 
       RowBox[{
        RowBox[{"Sum", "[", 
         RowBox[{
          SubscriptBox["mysparseEnergy", 
