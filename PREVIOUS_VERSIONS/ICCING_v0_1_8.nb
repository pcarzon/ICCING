Cell[CellGroupData[{

Cell["Discretization of Continuous Initial Condition", "Subsubsection",
 CellChangeTimes->{{3.768236723320484*^9, 3.7682367262544737`*^9}, {
  3.7683093549989295`*^9, 
  3.768309372560935*^9}},ExpressionUUID->"ec169579-b23f-4ba4-92e4-\
fb84d7fcb8dc"],

Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Scans", " ", "the", " ", "continuous", " ", "Qs", " ", "and", " ", 
     "gluon", " ", "density", " ", "distributions", " ", "and", " ", 
     "discretizes", " ", "them"}], ",", " ", 
    RowBox[{
    "throwing", " ", "away", " ", "values", " ", "too", " ", "close", " ", 
     "to", " ", "zero"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Discretize", "[", 
    RowBox[{"Q_", ",", "G_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"myi", ",", "myj", ",", "myx", ",", "myy", ",", "temp", ",", 
       RowBox[{"myQsPts", "=", 
        RowBox[{"{", "}"}]}], ",", 
       RowBox[{"mynGPts", "=", 
        RowBox[{"{", "}"}]}], ",", 
       RowBox[{"mynGdiscPts", "=", 
        RowBox[{"{", "}"}]}], ",", "myQsGrid", ",", "mynGGrid", ",", 
       "mynGdiscGrid"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"status", "=", "\"\<Discretizing Initial Condition\>\""}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Parallelize", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"myi", "=", "1"}], ",", 
          RowBox[{"myi", "\[LessEqual]", "imax"}], ",", 
          RowBox[{"myi", "++"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"For", "[", 
            RowBox[{
             RowBox[{"myj", "=", "1"}], ",", 
             RowBox[{"myj", "\[LessEqual]", "jmax"}], ",", 
             RowBox[{"myj", "++"}], ",", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"myx", "=", 
               RowBox[{"xmin", "+", 
                RowBox[{"myi", " ", "dx"}]}]}], ";", 
              "                             ", 
              RowBox[{"(*", "  ", 
               RowBox[{
                RowBox[{
                 RowBox[{"Inverting", ":", "  ", "i"}], " ", "=", " ", 
                 FractionBox[
                  RowBox[{"x", "-", "xmin"}], "dx"]}], ",", "  ", 
                RowBox[{"j", "=", 
                 FractionBox[
                  RowBox[{"y", "-", "ymin"}], "dy"]}]}], " ", "*)"}], 
              "\[IndentingNewLine]", 
              RowBox[{"myy", "=", 
               RowBox[{"ymin", "+", 
                RowBox[{"myj", " ", "dy"}]}]}], ";", "\[IndentingNewLine]", 
              RowBox[{"temp", "=", 
               RowBox[{"Chop", "[", 
                RowBox[{
                 RowBox[{"Q", "[", 
                  RowBox[{"myx", ",", "myy"}], "]"}], ",", "errfloor"}], 
                "]"}]}], ";", "\[IndentingNewLine]", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"temp", ">", "0"}], ",", 
                RowBox[{"AppendTo", "[", 
                 RowBox[{"myQsPts", ",", 
                  RowBox[{
                   RowBox[{"{", 
                    RowBox[{"myi", ",", "myj"}], "}"}], "->", "temp"}]}], 
                 "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
              RowBox[{"temp", "=", 
               RowBox[{"Chop", "[", 
                RowBox[{
                 RowBox[{"G", "[", 
                  RowBox[{"myx", ",", "myy"}], "]"}], ",", "errfloor"}], 
                "]"}]}], ";", "\[IndentingNewLine]", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"temp", ">", "0"}], ",", "\[IndentingNewLine]", 
                RowBox[{
                 RowBox[{"AppendTo", "[", 
                  RowBox[{"mynGPts", ",", 
                   RowBox[{
                    RowBox[{"{", 
                    RowBox[{"myi", ",", "myj"}], "}"}], "->", "temp"}]}], 
                  "]"}], ";", "\[IndentingNewLine]", 
                 RowBox[{"AppendTo", "[", 
                  RowBox[{"mynGdiscPts", ",", 
                   RowBox[{
                    RowBox[{"{", 
                    RowBox[{"myi", ",", "myj"}], "}"}], "\[Rule]", 
                    RowBox[{"Ceiling", "[", 
                    RowBox[{"temp", "*", "dx", "*", "dy"}], "]"}]}]}], "]"}], 
                 ";"}]}], "\[IndentingNewLine]", "]"}], ";"}]}], 
            "\[IndentingNewLine]", "]"}], ";"}]}], "\[IndentingNewLine]", 
         "]"}], ";"}], "\[IndentingNewLine]", "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"myQsGrid", "=", 
       RowBox[{"SparseArray", "[", 
        RowBox[{"myQsPts", ",", 
         RowBox[{"{", 
          RowBox[{"imax", ",", "jmax"}], "}"}], ",", "0"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"mynGGrid", "=", 
       RowBox[{"SparseArray", "[", 
        RowBox[{"mynGPts", ",", 
         RowBox[{"{", 
          RowBox[{"imax", ",", "jmax"}], "}"}], ",", "0"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"mynGdiscGrid", "=", 
       RowBox[{"SparseArray", "[", 
        RowBox[{"mynGdiscPts", ",", 
         RowBox[{"{", 
          RowBox[{"imax", ",", "jmax"}], "}"}], ",", "0"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Return", "[", 
       RowBox[{"{", 
        RowBox[{"myQsGrid", ",", "mynGGrid", ",", "mynGdiscGrid"}], "}"}], 
       "]"}], ";"}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"Returns", " ", "three", " ", "grids", " ", "as", " ", 
    RowBox[{"SparseArarys", ":", " ", 
     RowBox[{"{", 
      RowBox[{"Qs", ",", " ", 
       RowBox[{
       "continuous", " ", "energy", " ", "or", " ", "gluon", " ", "density", 
        " ", "at", " ", "point"}], ",", " ", 
       RowBox[{
       "integer", " ", "gluon", " ", "number", " ", "in", " ", "cell"}]}], 
      "}"}]}]}], " ", "*)"}], "*)"}]], "Input",
 CellChangeTimes->{{3.7682369269821196`*^9, 3.768237022365782*^9}, {
   3.768237062407637*^9, 3.7682370628338556`*^9}, {3.7682375815216618`*^9, 
   3.7682375848943233`*^9}, {3.7683055869291043`*^9, 3.768305588924656*^9}, {
   3.7683056314741383`*^9, 3.7683056401946745`*^9}, {3.768305697023512*^9, 
   3.768305751695282*^9}, {3.7683057818721685`*^9, 3.768305805342847*^9}, {
   3.768305841456833*^9, 3.7683060846536407`*^9}, {3.7683070758759747`*^9, 
   3.7683070958424325`*^9}, {3.768307131344286*^9, 3.7683071730638895`*^9}, 
   3.768308037253252*^9},
 CellLabel->
  "In[123]:=",ExpressionUUID->"1ffec5bb-a9a9-41a1-b753-b7c1bb9c9ad9"]
}, Closed]],

Cell[CellGroupData[{

Cell["Discrete Energy + Charge Redistribution Algorithm", "Subsubsection",
 CellChangeTimes->{
  3.7695279788493314`*^9, {3.770212541551901*^9, 
   3.7702125424846053`*^9}},ExpressionUUID->"473a7de0-521a-4665-8d08-\
3df7dc5ac323"],

Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{"(*", " ", "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "This", " ", "algorithm", " ", "is", " ", "used", " ", "when", " ", 
     RowBox[{"sampling", " ", "/", " ", "distributing"}], " ", "partons", " ",
      "for", " ", "one", " ", "grid", " ", "point", " ", "at", " ", "a", " ", 
     RowBox[{"time", ".", "  ", "It"}], " ", "is", " ", "now", " ", 
     "obsolete", " ", "becuse", " ", "of", " ", "the", " ", "new", " ", 
     "DistributeCharge2", " ", "algorithm", " ", "which", " ", "uses", " ", 
     "partons", " ", "of", " ", "a", " ", "finite", " ", "area"}], ",", " ", 
    RowBox[{"encompassing", " ", "many", " ", "grid", " ", 
     RowBox[{
     "points", ".", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      "Algorithm"}], " ", "that", " ", "steps", " ", "through", " ", "the", 
     " ", "grid", " ", "of", " ", "integer", " ", "#", " ", "of", " ", 
     "gluons"}], ",", " ", 
    RowBox[{"rolls", " ", "their", " ", "splitting", " ", "outcomes"}], ",", 
    " ", 
    RowBox[{
    "then", " ", "redistributes", " ", "charges", " ", "and", " ", 
     "energy"}]}], " ", "\[IndentingNewLine]", "\[IndentingNewLine]", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"DistributeCharge", "[", 
    RowBox[{"InQsGrid_", ",", "InNgGrid_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "ival", ",", "jval", ",", "k", ",", "num", ",", "result", ",", "flav", 
       ",", "\[Alpha]res", ",", "nB", ",", "nS", ",", "nQ", ",", 
       "\[CapitalDelta]i", ",", "\[CapitalDelta]j", ",", 
       "\[IndentingNewLine]", 
       RowBox[{"NewEnGrid", "=", "InNgGrid"}], ",", "\[IndentingNewLine]", 
       RowBox[{"NewNBGrid", "=", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{"0", ",", 
          RowBox[{"Dimensions", "[", "InNgGrid", "]"}]}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"NewNSGrid", "=", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{"0", ",", 
          RowBox[{"Dimensions", "[", "InNgGrid", "]"}]}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"NewNQGrid", "=", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{"0", ",", 
          RowBox[{"Dimensions", "[", "InNgGrid", "]"}]}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"NewUpGrid", "=", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{"0", ",", 
          RowBox[{"Dimensions", "[", "InNgGrid", "]"}]}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"NewUBarGrid", "=", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{"0", ",", 
          RowBox[{"Dimensions", "[", "InNgGrid", "]"}]}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"NewDownGrid", "=", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{"0", ",", 
          RowBox[{"Dimensions", "[", "InNgGrid", "]"}]}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"NewDBarGrid", "=", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{"0", ",", 
          RowBox[{"Dimensions", "[", "InNgGrid", "]"}]}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"NewStrangeGrid", "=", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{"0", ",", 
          RowBox[{"Dimensions", "[", "InNgGrid", "]"}]}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"NewSBarGrid", "=", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{"0", ",", 
          RowBox[{"Dimensions", "[", "InNgGrid", "]"}]}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"NewCharmGrid", "=", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{"0", ",", 
          RowBox[{"Dimensions", "[", "InNgGrid", "]"}]}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"NewCBarGrid", "=", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{"0", ",", 
          RowBox[{"Dimensions", "[", "InNgGrid", "]"}]}], "]"}]}]}], 
      "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"PrintTemporary", "[", 
       RowBox[{"Dynamic", "[", 
        RowBox[{"{", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"ToString", "[", "ival", "]"}], "<>", "\"\</\>\"", "<>", 
           RowBox[{"ToString", "[", "imax", "]"}]}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"ToString", "[", "jval", "]"}], "<>", "\"\</\>\"", "<>", 
           RowBox[{"ToString", "[", "jmax", "]"}]}], ",", 
          "\[IndentingNewLine]", "k"}], "}"}], "]"}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"status", "=", "\"\<Redistributing quarks\>\""}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"ival", "=", "1"}], ",", 
        RowBox[{"ival", "\[LessEqual]", "imax"}], ",", 
        RowBox[{"ival", "++"}], ",", "\[IndentingNewLine]", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"jval", "=", "1"}], ",", 
          RowBox[{"jval", "\[LessEqual]", "jmax"}], ",", 
          RowBox[{"jval", "++"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"num", "=", 
            SubscriptBox["InNgGrid", 
             RowBox[{"\[LeftDoubleBracket]", 
              RowBox[{"ival", ",", "jval"}], "\[RightDoubleBracket]"}]]}], 
           ";", "\[IndentingNewLine]", 
           RowBox[{"For", "[", 
            RowBox[{
             RowBox[{"k", "=", "1"}], ",", 
             RowBox[{"k", "\[LessEqual]", "num"}], ",", 
             RowBox[{"k", "++"}], ",", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"result", "=", 
               RowBox[{"SplittingSample", "[", 
                SubscriptBox["InQsGrid", 
                 RowBox[{"\[LeftDoubleBracket]", 
                  RowBox[{"ival", ",", "jval"}], "\[RightDoubleBracket]"}]], 
                "]"}]}], ";", "\[IndentingNewLine]", 
              RowBox[{"flav", "=", 
               SubscriptBox["result", 
                RowBox[{"\[LeftDoubleBracket]", 
                 RowBox[{"1", ",", "1"}], "\[RightDoubleBracket]"}]]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"\[Alpha]res", "=", 
               SubscriptBox["result", 
                RowBox[{"\[LeftDoubleBracket]", 
                 RowBox[{"2", ",", "1"}], "\[RightDoubleBracket]"}]]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"nB", "=", 
               SubscriptBox["result", 
                RowBox[{"\[LeftDoubleBracket]", 
                 RowBox[{"1", ",", "3"}], "\[RightDoubleBracket]"}]]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"nS", "=", 
               SubscriptBox["result", 
                RowBox[{"\[LeftDoubleBracket]", 
                 RowBox[{"1", ",", "4"}], "\[RightDoubleBracket]"}]]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"nQ", "=", 
               SubscriptBox["result", 
                RowBox[{"\[LeftDoubleBracket]", 
                 RowBox[{"1", ",", "5"}], "\[RightDoubleBracket]"}]]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"\[CapitalDelta]i", "=", 
               RowBox[{"Round", "[", 
                FractionBox[
                 SubscriptBox["result", 
                  RowBox[{"\[LeftDoubleBracket]", 
                   RowBox[{"2", ",", "2"}], "\[RightDoubleBracket]"}]], "dx"],
                 "]"}]}], ";", "\[IndentingNewLine]", 
              RowBox[{"\[CapitalDelta]j", "=", 
               RowBox[{"Round", "[", 
                FractionBox[
                 SubscriptBox["result", 
                  RowBox[{"\[LeftDoubleBracket]", 
                   RowBox[{"2", ",", "3"}], "\[RightDoubleBracket]"}]], "dy"],
                 "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"ival", "+", "\[CapitalDelta]i"}], ">", "imax"}], 
                  ")"}], "\[Or]", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"ival", "-", "\[CapitalDelta]i"}], "<", "1"}], 
                  ")"}], "\[Or]", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"jval", "+", "\[CapitalDelta]j"}], ">", "jmax"}], 
                  ")"}], "\[Or]", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"jval", "-", "\[CapitalDelta]j"}], "<", "1"}], 
                  ")"}]}], ",", "\[IndentingNewLine]", 
                RowBox[{
                 RowBox[{
                 "Print", "[", "\"\<Sampling out of bounds\>\"", "]"}], ";", 
                 RowBox[{"ErrFlag", "=", "True"}], ";", "Abort", ";"}]}], 
               "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
              RowBox[{
               SubscriptBox["NewEnGrid", 
                RowBox[{"\[LeftDoubleBracket]", 
                 RowBox[{"ival", ",", "jval"}], "\[RightDoubleBracket]"}]], 
               "--"}], ";", "\[IndentingNewLine]", 
              RowBox[{
               SubscriptBox["NewEnGrid", 
                RowBox[{"\[LeftDoubleBracket]", 
                 RowBox[{
                  RowBox[{"ival", "+", "\[CapitalDelta]i"}], ",", 
                  RowBox[{"jval", "+", "\[CapitalDelta]j"}]}], 
                 "\[RightDoubleBracket]"}]], "+=", "\[Alpha]res"}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{
               SubscriptBox["NewEnGrid", 
                RowBox[{"\[LeftDoubleBracket]", 
                 RowBox[{
                  RowBox[{"ival", "-", "\[CapitalDelta]i"}], ",", 
                  RowBox[{"jval", "-", "\[CapitalDelta]j"}]}], 
                 "\[RightDoubleBracket]"}]], "+=", 
               RowBox[{"1", "-", "\[Alpha]res"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{
               SubscriptBox["NewNBGrid", 
                RowBox[{"\[LeftDoubleBracket]", 
                 RowBox[{
                  RowBox[{"ival", "+", "\[CapitalDelta]i"}], ",", 
                  RowBox[{"jval", "+", "\[CapitalDelta]j"}]}], 
                 "\[RightDoubleBracket]"}]], "+=", "nB"}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{
               SubscriptBox["NewNBGrid", 
                RowBox[{"\[LeftDoubleBracket]", 
                 RowBox[{
                  RowBox[{"ival", "-", "\[CapitalDelta]i"}], ",", 
                  RowBox[{"jval", "-", "\[CapitalDelta]j"}]}], 
                 "\[RightDoubleBracket]"}]], "-=", "nB"}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{
               SubscriptBox["NewNSGrid", 
                RowBox[{"\[LeftDoubleBracket]", 
                 RowBox[{
                  RowBox[{"ival", "+", "\[CapitalDelta]i"}], ",", 
                  RowBox[{"jval", "+", "\[CapitalDelta]j"}]}], 
                 "\[RightDoubleBracket]"}]], "+=", "nS"}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{
               SubscriptBox["NewNSGrid", 
                RowBox[{"\[LeftDoubleBracket]", 
                 RowBox[{
                  RowBox[{"ival", "-", "\[CapitalDelta]i"}], ",", 
                  RowBox[{"jval", "-", "\[CapitalDelta]j"}]}], 
                 "\[RightDoubleBracket]"}]], "-=", "nS"}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{
               SubscriptBox["NewNQGrid", 
                RowBox[{"\[LeftDoubleBracket]", 
                 RowBox[{
                  RowBox[{"ival", "+", "\[CapitalDelta]i"}], ",", 
                  RowBox[{"jval", "+", "\[CapitalDelta]j"}]}], 
                 "\[RightDoubleBracket]"}]], "+=", "nQ"}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{
               SubscriptBox["NewNQGrid", 
                RowBox[{"\[LeftDoubleBracket]", 
                 RowBox[{
                  RowBox[{"ival", "-", "\[CapitalDelta]i"}], ",", 
                  RowBox[{"jval", "-", "\[CapitalDelta]j"}]}], 
                 "\[RightDoubleBracket]"}]], "-=", "nQ"}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"flav", "\[Equal]", "\"\<u\>\""}], ",", 
                "\[IndentingNewLine]", 
                RowBox[{
