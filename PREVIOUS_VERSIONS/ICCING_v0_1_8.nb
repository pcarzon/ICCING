       RowBox[{"StringJoin", "[", 
        RowBox[{"\"\<TA\>\"", ",", 
         RowBox[{"ToString", "[", "num", "]"}], ",", "\"\<.dat\>\""}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"myTBfile", "=", 
       RowBox[{"StringJoin", "[", 
        RowBox[{"\"\<TB\>\"", ",", 
         RowBox[{"ToString", "[", "num", "]"}], ",", "\"\<.dat\>\""}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"myTRfile", "=", 
       RowBox[{"StringJoin", "[", 
        RowBox[{"\"\<ic\>\"", ",", 
         RowBox[{"ToString", "[", "num", "]"}], ",", "\"\<.dat\>\""}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"myTA", "=", 
       RowBox[{"Delete", "[", 
        RowBox[{
         RowBox[{"Import", "[", "myTAfile", "]"}], ",", "1"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"myTB", "=", 
       RowBox[{"Delete", "[", 
        RowBox[{
         RowBox[{"Import", "[", "myTBfile", "]"}], ",", "1"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"myTR", "=", 
       RowBox[{"Delete", "[", 
        RowBox[{
         RowBox[{"Import", "[", "myTRfile", "]"}], ",", "1"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"mydata", "=", 
       RowBox[{"Part", "[", 
