Cell[TextData[StyleBox["\nYes, it seems to always correctly find a ceiling \
for any quark flavor and for a huge range of Qs.    \n\n\nNow let\
\[CloseCurlyQuote]s integrate it into the sampler and verify that it \
reproduces the input distribution.\n",
 FontWeight->"Bold"]], "Text",
 CellChangeTimes->{{3.8025284445422187`*^9, 3.8025284847806845`*^9}, {
  3.802528740892324*^9, 3.8025288181933794`*^9}, {3.802531347257676*^9, 
  3.802531356492985*^9}, {3.8025314293852205`*^9, 3.8025315756725245`*^9}, {
  3.802531641660137*^9, 3.802531674155819*^9}, {3.80253172953129*^9, 
  3.8025317641725845`*^9}, {3.8025319683008127`*^9, 3.802531994169647*^9}, {
  3.802536001638242*^9, 3.802536029139614*^9}, {3.8025415639960003`*^9, 
  3.8025415678507166`*^9}, {3.8025428092145557`*^9, 3.8025428245889854`*^9}, {
  3.8025429922177367`*^9, 3.8025430582497516`*^9}, {3.8025431406533957`*^9, 
  3.802543152028289*^9}, {3.802543217002043*^9, 3.802543217161584*^9}, {
  3.8025441628561907`*^9, 3.8025441947138762`*^9}, {3.802612854325898*^9, 
  3.8026128584388556`*^9}},
 FontColor->RGBColor[
  0, 0, 1],ExpressionUUID->"d9c1b1ea-689a-4620-91e5-5108afd93bfe"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuarkSample2", "[", 
   RowBox[{"m_", ",", "Qs_"}], "]"}], ":=", "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"r", ",", "\[Alpha]", ",", 
      RowBox[{"rfinal", "=", "\"\<\>\""}], ",", "MCceiling", ",", "y"}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"rfinal", "\[Equal]", "\"\<\>\""}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"r", " ", "=", " ", 
         RowBox[{"RandomReal", "[", 
          RowBox[{"{", 
           RowBox[{"0", ",", "rmax"}], "}"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"\[Alpha]", "=", 
         RowBox[{"RandomReal", "[", 
          RowBox[{"{", 
           RowBox[{"\[Alpha]min", ",", 
            RowBox[{"1", "-", "\[Alpha]min"}]}], "}"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"MCceiling", "=", 
         RowBox[{"1.01", "*", 
          SubscriptBox[
           RowBox[{"FindMaximum", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"corr", "[", 
                RowBox[{"r", ",", "0", ",", "m", ",", "Qs"}], "]"}], ",", 
               RowBox[{"0", "<", "r", "<", "rmax"}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"r", ",", "0.2"}], "}"}]}], "]"}], 
           RowBox[{
           "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"y", " ", "=", " ", 
         RowBox[{"RandomReal", "[", 
          RowBox[{"{", 
           RowBox[{"0", ",", "MCceiling"}], "}"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"y", "<", 
           RowBox[{"corr", "[", 
            RowBox[{"r", ",", "\[Alpha]", ",", "m", ",", "Qs"}], "]"}]}], ",", 
          RowBox[{"rfinal", "=", "r"}]}], "]"}], ";"}]}], 
      "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"{", 
       RowBox[{"\[Alpha]", ",", "rfinal"}], "}"}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.802545041959191*^9, 3.80254507898761*^9}, {
   3.802545118098217*^9, 3.8025452264903727`*^9}, {3.8025647467063427`*^9, 
   3.8025647734258747`*^9}, 3.802596153143439*^9, 3.8025965822501945`*^9, 
   3.8026128660455627`*^9},ExpressionUUID->"cd19c0f2-1d1d-4026-a8ef-\
241128bad7ef"],

Cell[TextData[StyleBox["\nThis routine is just the part which samples the 2D \
probability distribution.  We\[CloseCurlyQuote]ll test to see if it \
reproduces the input distribution.\n",
 FontWeight->"Bold"]], "Text",
 CellChangeTimes->{{3.8025284445422187`*^9, 3.8025284847806845`*^9}, {
  3.802528740892324*^9, 3.8025288181933794`*^9}, {3.802531347257676*^9, 
  3.802531356492985*^9}, {3.8025314293852205`*^9, 3.8025315756725245`*^9}, {
  3.802531641660137*^9, 3.802531674155819*^9}, {3.80253172953129*^9, 
  3.8025317641725845`*^9}, {3.8025319683008127`*^9, 3.802531994169647*^9}, {
  3.802536001638242*^9, 3.802536029139614*^9}, {3.8025415639960003`*^9, 
  3.8025415678507166`*^9}, {3.8025428092145557`*^9, 3.8025428245889854`*^9}, {
  3.8025429922177367`*^9, 3.8025430582497516`*^9}, {3.8025431406533957`*^9, 
  3.802543152028289*^9}, {3.802543217002043*^9, 3.802543217161584*^9}, {
  3.8025441628561907`*^9, 3.8025441947138762`*^9}, {3.8025453543138103`*^9, 
  3.8025453910983405`*^9}},
 FontColor->RGBColor[
  0, 0, 1],ExpressionUUID->"29564ae0-bebf-4200-9c72-2b2d5f381320"],

Cell[BoxData[
 RowBox[{
  RowBox[{"dataset", "=", 
   RowBox[{"{", "}"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.8025462280903196`*^9, 3.8025462312409573`*^9}},
 CellLabel->
  "In[1817]:=",ExpressionUUID->"f8b36105-3e23-4eaa-ab26-612cc1dc562f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"thismass", "=", "0.095"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"thisQ", "=", "2"}], ";"}]}], "Input",
 CellChangeTimes->{{3.8025488538936*^9, 3.802548863957555*^9}, {
  3.8025489232515736`*^9, 3.8025489265258026`*^9}, {3.802601570448167*^9, 
  3.802601581898698*^9}, {3.802606269411297*^9, 3.8026062866302834`*^9}, {
  3.8026064173944044`*^9, 3.8026064273458266`*^9}, {3.802611398268846*^9, 
  3.8026114036234875`*^9}, {3.802611544153138*^9, 3.8026115468359947`*^9}, {
  3.8026116019765573`*^9, 3.802611607783002*^9}},
 CellLabel->
  "In[167]:=",ExpressionUUID->"a05bd3a5-7784-4ed8-94ed-ab75e408187f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"quarkhisto", "[", 
   RowBox[{"d\[Alpha]_", ",", "dr_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "c", ",", "pl1", ",", "pl2", ",", "rawdata", ",", "scaleddata", ",", 
      "bincenters", ",", "histo"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"rawdata", "=", 
      RowBox[{"BinCounts", "[", 
       RowBox[{"dataset", ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "1", ",", "d\[Alpha]"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "rmax", ",", "dr"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"scaleddata", "=", 
      RowBox[{"rawdata", "/", 
       RowBox[{"Max", "[", "rawdata", "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"bincenters", " ", "=", " ", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"\[Alpha]min", "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"i", "-", 
              RowBox[{"1", "/", "2"}]}], ")"}], "*", "d\[Alpha]"}]}], ",", 
          RowBox[{"0", "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"j", "-", 
              RowBox[{"1", "/", "2"}]}], ")"}], "*", "dr"}]}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", 
          FractionBox["1", "d\[Alpha]"]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "1", ",", 
          FractionBox["rmax", "dr"]}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"histo", "=", 
      RowBox[{"Flatten", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            SubscriptBox["bincenters", 
             RowBox[{"\[LeftDoubleBracket]", 
              RowBox[{"i", ",", "j", ",", "1"}], "\[RightDoubleBracket]"}]], 
            ",", 
            SubscriptBox["bincenters", 
             RowBox[{"\[LeftDoubleBracket]", 
              RowBox[{"i", ",", "j", ",", "2"}], "\[RightDoubleBracket]"}]], 
            ",", 
            SubscriptBox["scaleddata", 
             RowBox[{"\[LeftDoubleBracket]", 
              RowBox[{"i", ",", "j"}], "\[RightDoubleBracket]"}]]}], "}"}], 
          ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", 
            FractionBox["1", "d\[Alpha]"]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", "1", ",", 
            FractionBox["rmax", "dr"]}], "}"}]}], "]"}], ",", "1"}], "]"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"pl1", "=", 
      RowBox[{"ListPlot3D", "[", 
       RowBox[{"histo", ",", 
        RowBox[{"AxesLabel", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{
          "\"\<\[Alpha]\>\"", ",", "\"\<r\>\"", ",", 
           "\"\<P(\[Alpha],r)\>\""}], "}"}]}], ",", 
        RowBox[{"ImageSize", "\[Rule]", "500"}], ",", 
        RowBox[{"LabelStyle", "\[Rule]", 
         RowBox[{"Directive", "[", 
          RowBox[{"18", ",", "Black"}], "]"}]}], ",", 
        RowBox[{"PlotRange", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"0", ",", "1"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"0", ",", "rmax"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"0", ",", "1"}], "}"}]}], "}"}]}], ",", 
        RowBox[{
        "PlotLabel", "\[Rule]", "\"\<Strange Quarks, Qs = 2 GeV\>\""}]}], 
       "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"c", "=", 
      SubscriptBox[
       RowBox[{"FindMaximum", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"corr", "[", 
            RowBox[{"r", ",", "0", ",", "thismass", ",", "thisQ"}], "]"}], 
           ",", 
           RowBox[{"0", "<", "r", "<", "rmax"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"r", ",", "0.2"}], "}"}]}], "]"}], 
       RowBox[{"\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]]}], ";",
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"pl2", "=", 
      RowBox[{"Plot3D", "[", 
       RowBox[{
        FractionBox[
         RowBox[{"corr", "[", 
          RowBox[{"r", ",", "\[Alpha]", ",", "thismass", ",", "thisQ"}], 
          "]"}], "c"], ",", 
        RowBox[{"{", 
         RowBox[{"\[Alpha]", ",", "0", ",", "1"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"r", ",", "0", ",", 
          RowBox[{"rmax", "*", "1.01"}]}], "}"}], ",", 
        RowBox[{"AxesLabel", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{
          "\"\<\[Alpha]\>\"", ",", "\"\<r\>\"", ",", 
           "\"\<P(\[Alpha],r)\>\""}], "}"}]}], ",", 
        RowBox[{"ImageSize", "\[Rule]", "500"}], ",", 
        RowBox[{"LabelStyle", "\[Rule]", 
         RowBox[{"Directive", "[", 
          RowBox[{"18", ",", "Black"}], "]"}]}], ",", 
        RowBox[{"PlotStyle", "\[Rule]", 
         RowBox[{"Directive", "[", 
          RowBox[{"Green", ",", 
           RowBox[{"Opacity", "[", "0.5", "]"}]}], "]"}]}], ",", 
        RowBox[{"PlotRange", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"0", ",", "1"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"0", ",", "rmax"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"0", ",", "1"}], "}"}]}], "}"}]}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<N = \>\"", ",", 
       RowBox[{"Length", "[", "dataset", "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<m = \>\"", ",", "thismass"}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<Qs = \>\"", ",", "thisQ"}], "]"}], ";", 
